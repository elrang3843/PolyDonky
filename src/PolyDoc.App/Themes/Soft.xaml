<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PolyDoc Soft Theme — 눈에 편한 따뜻한 색조 (학생·장년 대상) -->

    <Color x:Key="BrandPrimaryColor">#5B8C5A</Color>
    <Color x:Key="BrandPrimaryDarkColor">#3E6B3D</Color>
    <Color x:Key="SurfaceColor">#FDFAF5</Color>
    <Color x:Key="SurfaceAltColor">#F0EBE0</Color>
    <Color x:Key="OnSurfaceColor">#2B2318</Color>
    <Color x:Key="OnSurfaceMutedColor">#6B5E4E</Color>
    <Color x:Key="DividerColor">#D8CFC0</Color>

    <SolidColorBrush x:Key="BrandPrimary"     Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="BrandPrimaryDark" Color="{StaticResource BrandPrimaryDarkColor}" />
    <SolidColorBrush x:Key="Surface"          Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAlt"       Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="OnSurface"        Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceMuted"   Color="{StaticResource OnSurfaceMutedColor}" />
    <SolidColorBrush x:Key="Divider"          Color="{StaticResource DividerColor}" />

    <FontFamily x:Key="UiFont">맑은 고딕, Malgun Gothic, Segoe UI</FontFamily>

</ResourceDictionary>
