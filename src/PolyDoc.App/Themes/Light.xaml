<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PolyDoc Light Theme — Phase B 첫 사이클 기본 테마.
         Phase B 다음 사이클에서 학생/청년/장년 대상 테마들을 추가한다. -->

    <Color x:Key="BrandPrimaryColor">#3F6FB6</Color>
    <Color x:Key="BrandPrimaryDarkColor">#2A4F86</Color>
    <Color x:Key="SurfaceColor">#FAFAFA</Color>
    <Color x:Key="SurfaceAltColor">#F0F2F5</Color>
    <Color x:Key="OnSurfaceColor">#1F1F1F</Color>
    <Color x:Key="OnSurfaceMutedColor">#5C5C5C</Color>
    <Color x:Key="DividerColor">#E0E0E0</Color>

    <SolidColorBrush x:Key="BrandPrimary" Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="BrandPrimaryDark" Color="{StaticResource BrandPrimaryDarkColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAlt" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="OnSurface" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceMuted" Color="{StaticResource OnSurfaceMutedColor}" />
    <SolidColorBrush x:Key="Divider" Color="{StaticResource DividerColor}" />

    <FontFamily x:Key="UiFont">맑은 고딕, Malgun Gothic, Segoe UI</FontFamily>

    <!-- Restore system colors to light-theme values when switching back from a dark theme -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}"         Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}"             Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}"          Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}"    Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"      Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"          Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"           Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"       Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}"         Color="{StaticResource OnSurfaceMutedColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"        Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"    Color="{StaticResource OnSurfaceColor}" />

    <!-- Implicit styles: Foreground/Background for UI chrome elements -->
    <Style TargetType="Menu" BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="StatusBar" BasedOn="{StaticResource {x:Type StatusBar}}">
        <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="StatusBarItem" BasedOn="{StaticResource {x:Type StatusBarItem}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background"   Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Foreground"   Value="{StaticResource OnSurface}" />
        <Setter Property="CaretBrush"   Value="{StaticResource OnSurface}" />
        <Setter Property="BorderBrush"  Value="{StaticResource Divider}" />
    </Style>
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource OnSurface}" />
    </Style>
    <Style TargetType="Separator" BasedOn="{StaticResource {x:Type Separator}}">
        <Setter Property="Background" Value="{StaticResource Divider}" />
    </Style>

</ResourceDictionary>
