<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ████████████████████████████████████████████████████████
    IWPF 문서편집기 툴바 아이콘 리소스 딕셔너리
    ████████████████████████████████████████████████████████

    사용법:
      1) App.xaml의 Application.Resources에 머지:
         <ResourceDictionary.MergedDictionaries>
             <ResourceDictionary Source="ToolbarIcons.xaml"/>
         </ResourceDictionary.MergedDictionaries>

      2) ToolBar/Button에 적용:
         <Button ToolTip="새 파일">
             <Image Source="{StaticResource Icon_FileNew}" Width="20" Height="20"/>
         </Button>

      3) 색상 변경이 필요하면 DrawingImage 대신
         Resources/icons/*.svg 를 SvgImage 라이브러리로 직접 로드하세요.
         (Svg.Skia 또는 SharpVectors 패키지 권장)
    ████████████████████████████████████████████████████████
    -->

    <!-- ── 공통 브러시 ──────────────────────────────────── -->
    <SolidColorBrush x:Key="IconForeground"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="IconAccentBlue"   Color="#378ADD"/>
    <SolidColorBrush x:Key="IconAccentRed"    Color="#E24B4A"/>
    <SolidColorBrush x:Key="IconAccentGreen"  Color="#1D9E75"/>
    <SolidColorBrush x:Key="IconAccentAmber"  Color="#BA7517"/>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- 1. 파일 메뉴                                      -->
    <!-- ══════════════════════════════════════════════════ -->

    <!-- 새 파일 (IWPF 모드) -->
    <DrawingImage x:Key="Icon_FileNew">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- 문서 외곽 -->
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="4,2,13,17" RadiusX="1.5" RadiusY="1.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- 텍스트 선 -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="7,7"  EndPoint="14,7"/>
                            <LineGeometry StartPoint="7,10" EndPoint="14,10"/>
                            <LineGeometry StartPoint="7,13" EndPoint="14,13"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- IWPF 스파크 (파란색) -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentBlue}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="15,1"   EndPoint="15,3.5"/>
                            <LineGeometry StartPoint="13.7,2.2" EndPoint="16.3,2.2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 불러오기 -->
    <DrawingImage x:Key="Icon_FileOpen">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><RectangleGeometry Rect="4,2,13,17" RadiusX="1.5" RadiusY="1.5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="7,7"  EndPoint="14,7"/>
                            <LineGeometry StartPoint="7,10" EndPoint="14,10"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- 올라가는 화살표 -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentBlue}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="12,14" EndPoint="12,20"/>
                            <PathGeometry Figures="M9.5,17 L12,20 L14.5,17"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 저장 -->
    <DrawingImage x:Key="Icon_FileSave">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="3,3,14,14"  RadiusX="1.5" RadiusY="1.5"/>
                            <RectangleGeometry Rect="6,3,6,4.5"  RadiusX="0.8" RadiusY="0.8"/>
                            <RectangleGeometry Rect="5.5,10,9,5.5" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 다른이름으로 저장 -->
    <DrawingImage x:Key="Icon_FileSaveAs">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="3,3,14,14"  RadiusX="1.5" RadiusY="1.5"/>
                            <RectangleGeometry Rect="6,3,6,4.5"  RadiusX="0.8" RadiusY="0.8"/>
                            <RectangleGeometry Rect="5.5,10,9,5.5" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- 파란 점: 다른이름 구분 -->
                <GeometryDrawing Brush="{StaticResource IconAccentBlue}">
                    <GeometryDrawing.Geometry><EllipseGeometry Center="19,18" RadiusX="2" RadiusY="2"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 미리보기 -->
    <DrawingImage x:Key="Icon_FilePreview">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><RectangleGeometry Rect="4,2,13,17" RadiusX="1.5" RadiusY="1.5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource IconAccentBlue}">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentBlue}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="10.5,13" RadiusX="3.5" RadiusY="2.5"/>
                            <EllipseGeometry Center="10.5,13" RadiusX="1"   RadiusY="1"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 인쇄 -->
    <DrawingImage x:Key="Icon_FilePrint">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="4,8,14,9"  RadiusX="1.5" RadiusY="1.5"/>
                            <RectangleGeometry Rect="6,2,10,7"  RadiusX="1"   RadiusY="1"/>
                            <RectangleGeometry Rect="6,12,10,6" RadiusX="1"   RadiusY="1"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="8,15" EndPoint="14,15"/>
                            <LineGeometry StartPoint="8,17" EndPoint="14,17"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 닫기 -->
    <DrawingImage x:Key="Icon_FileClose">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><RectangleGeometry Rect="4,2,13,17" RadiusX="1.5" RadiusY="1.5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="7,7"  EndPoint="14,7"/>
                            <LineGeometry StartPoint="7,10" EndPoint="14,10"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- 빨간 X -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentRed}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="8.5,14"  EndPoint="13.5,19"/>
                            <LineGeometry StartPoint="13.5,14" EndPoint="8.5,19"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- 2. 편집 메뉴                                      -->
    <!-- ══════════════════════════════════════════════════ -->

    <!-- 복사 -->
    <DrawingImage x:Key="Icon_EditCopy">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><RectangleGeometry Rect="3,6,11,14" RadiusX="1.5" RadiusY="1.5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><RectangleGeometry Rect="6,3,11,14" RadiusX="1.5" RadiusY="1.5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 찾기 -->
    <DrawingImage x:Key="Icon_EditFind">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><EllipseGeometry Center="10,10" RadiusX="6" RadiusY="6"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><LineGeometry StartPoint="14.5,14.5" EndPoint="20,20"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 바꾸기 -->
    <DrawingImage x:Key="Icon_EditReplace">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><EllipseGeometry Center="8,10" RadiusX="5" RadiusY="5"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><LineGeometry StartPoint="12,13.5" EndPoint="15.5,17"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentGreen}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <PathGeometry Figures="M16,14 Q21,11 21,17"/>
                            <PathGeometry Figures="M18.5,17 L21,17 L21,14.5"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- 서식 - 주요 글자 서식 (DrawingImage)              -->
    <!-- ══════════════════════════════════════════════════ -->

    <!-- 두껍게 -->
    <DrawingImage x:Key="Icon_FormatBold">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconForeground}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M6,3 L6,21 M6,3 Q15,3 15,7 Q15,11 6,11 M6,11 Q17,11 17,15.5 Q17,21 6,21"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 밑줄 -->
    <DrawingImage x:Key="Icon_FormatUnderline">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M5,3 L5,14 Q5,19 12,19 Q19,19 19,14 L19,3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><LineGeometry StartPoint="3,21" EndPoint="21,21"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 중간줄 -->
    <DrawingImage x:Key="Icon_FormatStrikethrough">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M17,7 Q17,3 12,3 Q7,3 7,7 Q7,11 12,11"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconAccentRed}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><LineGeometry StartPoint="2,12" EndPoint="22,12"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M7,17 Q7,21 12,21 Q17,21 17,17"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 설정 (톱니) -->
    <DrawingImage x:Key="Icon_ToolSettings">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M12,2 L13.2,6 L16.5,5 L19,7.5 L18,10.8 L21,12 L18,13.2 L19,16.5 L16.5,19 L13.2,18 L12,22 L10.8,18 L7.5,19 L5,16.5 L6,13.2 L3,12 L6,10.8 L5,7.5 L7.5,5 L10.8,6 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource IconForeground}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry><EllipseGeometry Center="12,12" RadiusX="3" RadiusY="3"/></GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 나머지 아이콘은 SVG 파일에서 SvgImage 라이브러리로 로드 권장
         (Svg.Skia / SharpVectors). 현재는 파일 메뉴만 DrawingImage 로 사용. -->

</ResourceDictionary>
