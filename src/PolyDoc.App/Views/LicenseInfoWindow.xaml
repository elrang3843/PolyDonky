<Window x:Class="PolyDoc.App.Views.LicenseInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="라이선스 및 참조"
        Width="760" Height="580"
        MinWidth="560" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- 탭 1: 이 제품의 라이선스 -->
            <TabItem Header="PolyDoc 라이선스">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="PolyDocLicenseText"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource OnSurface}"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Margin="8" />
                </ScrollViewer>
            </TabItem>

            <!-- 탭 2: 서드파티 라이선스 -->
            <TabItem Header="서드파티 라이선스">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="ThirdPartyText"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource OnSurface}"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Margin="8" />
                </ScrollViewer>
            </TabItem>

            <!-- 탭 3: 의존성 목록 -->
            <TabItem Header="의존성">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="배포 포함 의존성" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <DataGrid x:Name="ShippedDepsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceAlt}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource OnSurfaceMuted}"
                                  Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="패키지" Binding="{Binding Name}" Width="220" />
                                <DataGridTextColumn Header="버전" Binding="{Binding Version}" Width="100" />
                                <DataGridTextColumn Header="라이선스" Binding="{Binding License}" Width="120" />
                                <DataGridTextColumn Header="저작권자" Binding="{Binding Copyright}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="테스트 전용 의존성 (배포 미포함)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <DataGrid x:Name="TestDepsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{DynamicResource SurfaceAlt}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource OnSurfaceMuted}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="패키지" Binding="{Binding Name}" Width="220" />
                                <DataGridTextColumn Header="버전" Binding="{Binding Version}" Width="100" />
                                <DataGridTextColumn Header="라이선스" Binding="{Binding License}" Width="120" />
                                <DataGridTextColumn Header="저작권자" Binding="{Binding Copyright}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 탭 4: 파일 형식 명세 참조 -->
            <TabItem Header="파일 형식 명세">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <TextBlock Text="PolyDoc이 읽고 쓰는 파일 형식은 아래 공개 명세를 참조하여 구현되었습니다."
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   Foreground="{DynamicResource OnSurfaceMuted}" />

                        <!-- ECMA-376 / DOCX -->
                        <Border BorderBrush="{DynamicResource OnSurfaceMuted}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ECMA-376 / ISO/IEC 29500 — Office Open XML (DOCX)"
                                           FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="발행: ECMA International"
                                           Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,4,0,0" />
                                <TextBlock Text="용도: DOCX 읽기/쓰기 지원"
                                           Foreground="{DynamicResource OnSurfaceMuted}" />
                                <TextBlock Text="https://ecma-international.org/publications-and-standards/standards/ecma-376/"
                                           Foreground="{DynamicResource Primary}" Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- MS-DOC -->
                        <Border BorderBrush="{DynamicResource OnSurfaceMuted}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="[MS-DOC]: Word (.doc) Binary File Format"
                                           FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="발행: Microsoft Corporation (Open Specification Promise)"
                                           Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,4,0,0" />
                                <TextBlock Text="용도: 레거시 DOC 바이너리 포맷 참조 (ingest 전용)"
                                           Foreground="{DynamicResource OnSurfaceMuted}" />
                                <TextBlock Text="https://docs.microsoft.com/openspecs/office_file_formats/ms-doc/"
                                           Foreground="{DynamicResource Primary}" Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- OWPML / KS X 6101 -->
                        <Border BorderBrush="{DynamicResource OnSurfaceMuted}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="OWPML (Open Word Processor Markup Language) / KS X 6101 — HWPX"
                                           FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="발행: 한국산업표준 (Korean Industrial Standard)"
                                           Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,4,0,0" />
                                <TextBlock Text="용도: HWPX 읽기/쓰기 지원"
                                           Foreground="{DynamicResource OnSurfaceMuted}" />
                                <TextBlock Text="https://standard.go.kr/"
                                           Foreground="{DynamicResource Primary}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- HWP 5.0 -->
                        <StackPanel>
                            <TextBlock Text="HWP 5.0 Binary File Format Specification"
                                       FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="발행: 한글과컴퓨터 주식회사 (Hancom Inc.)"
                                       Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,4,0,0" />
                            <TextBlock Text="용도: HWP 5.x 바이너리 포맷 참조 (ingest 전용)"
                                       Foreground="{DynamicResource OnSurfaceMuted}" />
                            <TextBlock TextWrapping="Wrap" Margin="0,8,0,0"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource OnSurface}">
                                본 제품은 한글과컴퓨터의 HWP 문서 파일(.hwp) 공개 문서를 참고하여 개발하였습니다.
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Button Grid.Row="1"
                Content="닫기"
                Width="88" Height="32"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                IsDefault="True"
                IsCancel="True"
                Click="OnCloseClick" />
    </Grid>
</Window>
