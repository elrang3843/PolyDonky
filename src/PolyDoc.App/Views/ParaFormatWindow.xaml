<Window x:Class="PolyDoc.App.Views.ParaFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding FormatParaTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="16" MinWidth="450">

        <!-- 정렬 그룹 -->
        <GroupBox Margin="0,0,0,8" Padding="10,4,10,8">
            <GroupBox.Header>
                <TextBlock Text="{Binding FormatParaAlignGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                           FontWeight="SemiBold" />
            </GroupBox.Header>
            <WrapPanel>
                <RadioButton x:Name="RbAlignLeft" GroupName="Align" Margin="0,4,16,4"
                             Content="{Binding FormatParaAlignLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                             Checked="OnPreviewUpdate" />
                <RadioButton x:Name="RbAlignCenter" GroupName="Align" Margin="0,4,16,4"
                             Content="{Binding FormatParaAlignCenter, Source={x:Static svc:LocalizedStrings.Instance}}"
                             Checked="OnPreviewUpdate" />
                <RadioButton x:Name="RbAlignRight" GroupName="Align" Margin="0,4,16,4"
                             Content="{Binding FormatParaAlignRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                             Checked="OnPreviewUpdate" />
                <RadioButton x:Name="RbAlignJustify" GroupName="Align" Margin="0,4,16,4"
                             Content="{Binding FormatParaAlignJustify, Source={x:Static svc:LocalizedStrings.Instance}}"
                             Checked="OnPreviewUpdate" />
                <RadioButton x:Name="RbAlignDistributed" GroupName="Align" Margin="0,4,0,4"
                             Content="{Binding FormatParaAlignDistributed, Source={x:Static svc:LocalizedStrings.Instance}}"
                             Checked="OnPreviewUpdate" />
            </WrapPanel>
        </GroupBox>

        <!-- 간격 그룹 -->
        <GroupBox Margin="0,0,0,8" Padding="10,4,10,8">
            <GroupBox.Header>
                <TextBlock Text="{Binding FormatParaSpacingGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                           FontWeight="SemiBold" />
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding FormatParaLineHeight, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="1" x:Name="TxtLineHeight"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="2" Text="%"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <TextBlock Grid.Column="4"
                           Text="{Binding FormatParaSpaceBefore, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="10,0,6,0" />
                <TextBox Grid.Column="5" x:Name="TxtSpaceBefore"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="6" Text="pt"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <TextBlock Grid.Column="7"
                           Text="{Binding FormatParaSpaceAfter, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="10,0,6,0" />
                <TextBox Grid.Column="8" x:Name="TxtSpaceAfter"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="9" Text="pt"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
            </Grid>
        </GroupBox>

        <!-- 들여쓰기 그룹 -->
        <GroupBox Margin="0,0,0,8" Padding="10,4,10,8">
            <GroupBox.Header>
                <TextBlock Text="{Binding FormatParaIndentGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                           FontWeight="SemiBold" />
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding FormatParaIndentFirst, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="1" x:Name="TxtIndentFirst"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="2" Text="mm"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <TextBlock Grid.Column="4"
                           Text="{Binding FormatParaIndentLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="10,0,6,0" />
                <TextBox Grid.Column="5" x:Name="TxtIndentLeft"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="6" Text="mm"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <TextBlock Grid.Column="7"
                           Text="{Binding FormatParaIndentRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                           VerticalAlignment="Center" Margin="10,0,6,0" />
                <TextBox Grid.Column="8" x:Name="TxtIndentRight"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         VerticalAlignment="Center" Padding="4,3"
                         TextChanged="OnPreviewUpdate" />
                <TextBlock Grid.Column="9" Text="mm"
                           VerticalAlignment="Center" Margin="4,0,0,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
            </Grid>
        </GroupBox>

        <!-- 개요 수준 그룹 -->
        <GroupBox Margin="0,0,0,8" Padding="10,4,10,8">
            <GroupBox.Header>
                <TextBlock Text="{Binding FormatParaOutline, Source={x:Static svc:LocalizedStrings.Instance}}"
                           FontWeight="SemiBold" />
            </GroupBox.Header>
            <ComboBox x:Name="CboOutline"
                      Background="{DynamicResource SurfaceAlt}"
                      Foreground="{DynamicResource OnSurface}"
                      BorderBrush="{DynamicResource Divider}"
                      VerticalAlignment="Center"
                      SelectionChanged="OnPreviewUpdate" />
        </GroupBox>

        <!-- 미리보기 그룹 -->
        <GroupBox Margin="0,0,0,12" Padding="10,4,10,8">
            <GroupBox.Header>
                <TextBlock Text="{Binding FormatParaPreviewGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                           FontWeight="SemiBold" />
            </GroupBox.Header>
            <Border MinHeight="80"
                    BorderThickness="1" BorderBrush="{DynamicResource Divider}"
                    Background="{DynamicResource Surface}">
                <FlowDocumentScrollViewer x:Name="PreviewViewer"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"
                                          IsToolBarVisible="False"
                                          Padding="8" />
            </Border>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding DlgConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" IsDefault="True" Click="OnOk" />
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
