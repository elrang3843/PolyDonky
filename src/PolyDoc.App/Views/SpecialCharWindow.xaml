<Window x:Class="PolyDoc.App.Views.SpecialCharWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="특수문자"
        Width="720" Height="520"
        MinWidth="560" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 검색 / 코드 입력 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="유니코드(hex):" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="UnicodeInput"
                     VerticalContentAlignment="Center"
                     KeyDown="OnUnicodeInputKeyDown" />
            <Button Grid.Column="2" Content="찾기" Width="64" Margin="6,0,0,0"
                    Click="OnFindUnicode" />
            <TextBlock Grid.Column="3" Text="  예: 03B1, 2603, AC00"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       VerticalAlignment="Center" Margin="6,0,0,0" />
        </Grid>

        <!-- 본문: 좌측 카테고리 / 우측 글자 그리드 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" x:Name="CategoryList"
                     SelectionChanged="OnCategoryChanged"
                     BorderBrush="{DynamicResource OnSurfaceMuted}" />

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource OnSurfaceMuted}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CharGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Width="36" Height="36"
                                        Margin="2"
                                        FontSize="20"
                                        Click="OnCharButtonClick"
                                        MouseDoubleClick="OnCharButtonDoubleClick"
                                        ToolTip="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 미리보기 + 정보 -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Margin="0,8,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="PreviewText"
                           Text=" "
                           FontSize="48"
                           Width="72" Height="72"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="CodePointText"
                               Text="문자를 선택하세요"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CharNameText"
                               Foreground="{DynamicResource OnSurfaceMuted}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="삽입(_I)"
                    Width="96" Height="32"
                    Click="OnInsertClick"
                    IsDefault="True"
                    Margin="0,0,8,0" />
            <Button Content="닫기"
                    Width="96" Height="32"
                    Click="OnCloseClick"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
