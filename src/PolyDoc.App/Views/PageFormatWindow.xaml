<Window x:Class="PolyDoc.App.Views.PageFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding PageFormatTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="700" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="12">

        <!-- 본문: 좌(탭) / 우(미리보기) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <!-- ── 탭 패널 ── -->
            <TabControl Grid.Column="0"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Divider}">

                <!-- ── 용지 탭 ── -->
                <TabItem Header="{Binding PageFormatPaperTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <StackPanel Margin="10,8">

                        <!-- 용지 크기 -->
                        <TextBlock Text="{Binding PageFormatSizeLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="CboSize"
                                  Background="{DynamicResource SurfaceAlt}"
                                  Foreground="{DynamicResource OnSurface}"
                                  BorderBrush="{DynamicResource Divider}"
                                  Margin="0,0,0,10"
                                  SelectionChanged="OnSizeChanged" />

                        <!-- 사용자 정의 치수 -->
                        <Grid x:Name="PanelCustomSize" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding PageFormatWidthLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           Margin="0,0,0,2" />
                                <TextBox x:Name="TxtWidth" Padding="4,3"
                                         Background="{DynamicResource SurfaceAlt}"
                                         Foreground="{DynamicResource OnSurface}"
                                         BorderBrush="{DynamicResource Divider}"
                                         TextChanged="OnDimensionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding PageFormatHeightLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           Margin="0,0,0,2" />
                                <TextBox x:Name="TxtHeight" Padding="4,3"
                                         Background="{DynamicResource SurfaceAlt}"
                                         Foreground="{DynamicResource OnSurface}"
                                         BorderBrush="{DynamicResource Divider}"
                                         TextChanged="OnDimensionChanged" />
                            </StackPanel>
                        </Grid>

                        <!-- 방향 -->
                        <TextBlock Text="{Binding PageFormatOrientation, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="RbPortrait"
                                         Content="{Binding PageFormatPortrait, Source={x:Static svc:LocalizedStrings.Instance}}"
                                         GroupName="Orientation" IsChecked="True"
                                         Margin="0,0,16,0"
                                         Checked="OnOrientationChanged" />
                            <RadioButton x:Name="RbLandscape"
                                         Content="{Binding PageFormatLandscape, Source={x:Static svc:LocalizedStrings.Instance}}"
                                         GroupName="Orientation"
                                         Checked="OnOrientationChanged" />
                        </StackPanel>

                        <!-- 글자 방향 (가로/세로 + 진행 방향) -->
                        <TextBlock Text="글자 방향" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CboTextOrientation" Grid.Column="0"
                                      Background="{DynamicResource SurfaceAlt}"
                                      Foreground="{DynamicResource OnSurface}"
                                      BorderBrush="{DynamicResource Divider}"
                                      SelectionChanged="OnTextDirectionChanged">
                                <ComboBoxItem Content="가로 쓰기" />
                                <ComboBoxItem Content="세로 쓰기 (모델만 저장, 표시 미지원)" />
                            </ComboBox>
                            <ComboBox x:Name="CboTextProgression" Grid.Column="2"
                                      Background="{DynamicResource SurfaceAlt}"
                                      Foreground="{DynamicResource OnSurface}"
                                      BorderBrush="{DynamicResource Divider}"
                                      SelectionChanged="OnTextDirectionChanged">
                                <ComboBoxItem Content="오른쪽으로 진행" />
                                <ComboBoxItem Content="왼쪽으로 진행" />
                            </ComboBox>
                        </Grid>

                        <!-- 용지 색상 -->
                        <TextBlock Text="{Binding PageFormatPaperColor, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <DockPanel>
                            <CheckBox x:Name="ChkDefaultColor"
                                      DockPanel.Dock="Bottom"
                                      Content="{Binding PageFormatPaperColorDefault, Source={x:Static svc:LocalizedStrings.Instance}}"
                                      Margin="0,4,0,0"
                                      Checked="OnDefaultColorChanged" Unchecked="OnDefaultColorChanged" />
                            <Border x:Name="PaperColorSwatch"
                                    DockPanel.Dock="Right"
                                    Width="22" Height="22" Margin="6,0,0,0"
                                    BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnPaperColorSwatchClick" />
                            <TextBox x:Name="TxtPaperColor"
                                     Padding="4,3"
                                     Background="{DynamicResource SurfaceAlt}"
                                     Foreground="{DynamicResource OnSurface}"
                                     BorderBrush="{DynamicResource Divider}"
                                     TextChanged="OnPaperColorChanged" />
                        </DockPanel>

                    </StackPanel>
                </TabItem>

                <!-- ── 여백 탭 ── -->
                <TabItem Header="{Binding PageFormatMarginsTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <Grid Margin="10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding PageFormatMarginTop, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtMarginTop"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding PageFormatMarginBottom, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtMarginBottom"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{Binding PageFormatMarginLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtMarginLeft"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="6" Grid.Column="0"
                                   Text="{Binding PageFormatMarginRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TxtMarginRight"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="{Binding PageFormatMarginHeader, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="8" Grid.Column="1" x:Name="TxtMarginHeader"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="10" Grid.Column="0"
                                   Text="{Binding PageFormatMarginFooter, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="10" Grid.Column="1" x:Name="TxtMarginFooter"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <CheckBox  Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                                   x:Name="ChkShowMarginGuides"
                                   Content="{Binding PageFormatShowMarginGuides, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   Checked="OnShowMarginGuidesChanged"
                                   Unchecked="OnShowMarginGuidesChanged" />
                    </Grid>
                </TabItem>

                <!-- ── 레이아웃 탭 ── -->
                <TabItem Header="{Binding PageFormatLayoutTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <Grid Margin="10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding PageFormatColumns, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtColumns"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding PageFormatColumnGap, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtColumnGap"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{Binding PageFormatPageNumberStart, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtPageNumberStart"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- ── 미리보기 ── -->
            <GroupBox Grid.Column="2" Padding="6,4">
                <GroupBox.Header>
                    <TextBlock Text="{Binding PageFormatPreviewGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                               FontWeight="SemiBold" />
                </GroupBox.Header>
                <Border Background="{DynamicResource SurfaceAlt}"
                        BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                        Padding="6">
                    <Canvas x:Name="PreviewCanvas" Width="148" Height="200"
                            Background="Transparent" />
                </Border>
            </GroupBox>

        </Grid>

        <!-- 하단 버튼 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인" Padding="16,5" IsDefault="True" Click="OnOk" />
            <Button Content="취소" Padding="16,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>
