<Window x:Class="PolyDoc.App.Views.PasswordChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding PwdChangeTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="430" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="20" MinWidth="370">

        <!-- 어떤 암호를 설정할지 체크박스로 선택 -->
        <CheckBox x:Name="ChkRead"
                  Content="{Binding PwdChkRead, Source={x:Static svc:LocalizedStrings.Instance}}"
                  Margin="4,2"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged" />
        <CheckBox x:Name="ChkWrite"
                  Content="{Binding PwdChkWrite, Source={x:Static svc:LocalizedStrings.Instance}}"
                  Margin="4,2"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged" />
        <!-- 같은 암호 사용: 열기·쓰기 둘 다 체크됐을 때만 활성화 -->
        <CheckBox x:Name="ChkSame"
                  Content="{Binding PwdChkSame, Source={x:Static svc:LocalizedStrings.Instance}}"
                  Margin="22,2,4,2" IsEnabled="False"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged" />

        <!-- 단일 비밀번호 패널: 체크가 하나만 됐거나 같이사용이 체크된 경우 -->
        <StackPanel x:Name="PanelSingle" Margin="0,14,0,0" Visibility="Collapsed">
            <Label Content="{Binding PwdChangeNew, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,0,0,2" />
            <PasswordBox x:Name="PwdNew1"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
            <Label Content="{Binding PwdChangeConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,8,0,2" />
            <PasswordBox x:Name="PwdConfirm1"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
        </StackPanel>

        <!-- 이중 비밀번호 패널: 열기·쓰기 둘 다 체크되고 같이사용이 체크 안 된 경우 -->
        <StackPanel x:Name="PanelDual" Margin="0,14,0,0" Visibility="Collapsed">
            <!-- 열기 암호 -->
            <TextBlock Text="{Binding PwdChkRead, Source={x:Static svc:LocalizedStrings.Instance}}"
                       FontWeight="SemiBold" Margin="0,0,0,4" />
            <Label Content="{Binding PwdChangeNew, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,0,0,2" />
            <PasswordBox x:Name="PwdReadNew"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
            <Label Content="{Binding PwdChangeConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,8,0,2" />
            <PasswordBox x:Name="PwdReadConfirm"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />

            <!-- 쓰기 암호 -->
            <TextBlock Text="{Binding PwdChkWrite, Source={x:Static svc:LocalizedStrings.Instance}}"
                       FontWeight="SemiBold" Margin="0,12,0,4" />
            <Label Content="{Binding PwdChangeNew, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,0,0,2" />
            <PasswordBox x:Name="PwdWriteNew"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
            <Label Content="{Binding PwdChangeConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,8,0,2" />
            <PasswordBox x:Name="PwdWriteConfirm"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Foreground="#E74C3C" Margin="0,8,0,0"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding DlgConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" IsDefault="True" Click="OnOk" />
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
