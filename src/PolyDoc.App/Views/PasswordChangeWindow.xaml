<Window x:Class="PolyDoc.App.Views.PasswordChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding PwdChangeTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="430" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="20" MinWidth="370">

        <!-- 보호 모드 선택 -->
        <TextBlock Text="{Binding PwdModeGroupLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                   FontWeight="SemiBold" Margin="0,0,0,8" />

        <RadioButton x:Name="RadioNone"
                     Content="{Binding PwdModeNone, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="PwdMode" Margin="4,2"
                     Checked="OnModeChanged" />
        <RadioButton x:Name="RadioRead"
                     Content="{Binding PwdModeRead, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="PwdMode" Margin="4,2"
                     Checked="OnModeChanged" />
        <RadioButton x:Name="RadioWrite"
                     Content="{Binding PwdModeWrite, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="PwdMode" Margin="4,2"
                     Checked="OnModeChanged" />
        <RadioButton x:Name="RadioBoth"
                     Content="{Binding PwdModeBoth, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="PwdMode" Margin="4,2"
                     Checked="OnModeChanged" />

        <!-- 비밀번호 입력란 (None 선택 시 숨김) -->
        <StackPanel x:Name="PasswordPanel" Margin="0,14,0,0">
            <Label Content="{Binding PwdChangeNew, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,0,0,2" />
            <PasswordBox x:Name="NewPasswordInput"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />

            <Label Content="{Binding PwdChangeConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                   Padding="0,8,0,2" />
            <PasswordBox x:Name="ConfirmPasswordInput"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         CaretBrush="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         Padding="6,4" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Foreground="#E74C3C" Margin="0,8,0,0"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding DlgConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" IsDefault="True" Click="OnOk" />
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
