<Window x:Class="PolyDoc.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PolyDoc 정보"
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="160" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Source="pack://application:,,,/Assets/Handtech_1024.png"
               Width="140" Height="140"
               HorizontalAlignment="Center" />

        <TextBlock Grid.Row="1"
                   Text="PolyDoc"
                   FontSize="28" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0" />

        <TextBlock Grid.Row="2"
                   x:Name="VersionText"
                   Text="버전 1.0.0-test.1"
                   Foreground="{DynamicResource OnSurfaceMuted}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />

        <StackPanel Grid.Row="3" Margin="0,16,0,0" HorizontalAlignment="Center">
            <TextBlock Text="핸텍 (HANDTECH)"
                       FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="저작권자 / 메인테이너 — 노진문 (Noh JinMoon)"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
            <TextBlock Text="© 2026 HANDTECH. Apache License 2.0."
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Button Grid.Row="5"
                Content="확인"
                Width="96" Height="32"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OnOkClick" />
    </Grid>
</Window>
