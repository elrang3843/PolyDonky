<Window x:Class="PolyDoc.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="320" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{StaticResource UiFont}"
        Background="{StaticResource Surface}"
        Foreground="{StaticResource OnSurface}">

    <StackPanel Margin="20" MinWidth="280">

        <!-- 테마 -->
        <Label Content="테마:" FontWeight="SemiBold" Padding="0,0,0,4" />
        <RadioButton x:Name="ThemeLight" Content="라이트 (기본)" GroupName="Theme"
                     Margin="0,2" IsChecked="True" Checked="OnThemeChecked" />
        <RadioButton x:Name="ThemeDark"  Content="다크"          GroupName="Theme"
                     Margin="0,2" Checked="OnThemeChecked" />
        <RadioButton x:Name="ThemeSoft"  Content="소프트"        GroupName="Theme"
                     Margin="0,2" Checked="OnThemeChecked" />

        <Separator Margin="0,16,0,12" />

        <!-- 버튼 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="닫기" Padding="12,5" IsCancel="True" Click="OnClose" />
        </StackPanel>
    </StackPanel>
</Window>
