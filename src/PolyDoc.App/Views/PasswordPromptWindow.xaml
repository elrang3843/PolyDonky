<Window x:Class="PolyDoc.App.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding PwdPromptTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="20" MinWidth="320">
        <TextBlock Text="{Binding PwdPromptMessage, Source={x:Static svc:LocalizedStrings.Instance}}"
                   TextWrapping="Wrap" Margin="0,0,0,10" />

        <Label Content="{Binding PwdPromptInput, Source={x:Static svc:LocalizedStrings.Instance}}"
               Padding="0,0,0,2" />
        <PasswordBox x:Name="PasswordInput"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     CaretBrush="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}"
                     Padding="6,4" />

        <TextBlock x:Name="ErrorText"
                   Foreground="#E74C3C" Margin="0,8,0,0"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding DlgConfirm, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" IsDefault="True" Click="OnOk" />
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="14,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
