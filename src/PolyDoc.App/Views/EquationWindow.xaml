<Window x:Class="PolyDoc.App.Views.EquationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="수식 (LaTeX)"
        Width="720" Height="540"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 모드 선택 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="모드:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <RadioButton x:Name="RbInline" Content="줄 안 (inline) — \(...\)"
                         IsChecked="True" GroupName="EqMode"
                         VerticalAlignment="Center" Margin="0,0,16,0" />
            <RadioButton x:Name="RbDisplay" Content="별행 (display) — \[...\]"
                         GroupName="EqMode"
                         VerticalAlignment="Center" />
        </StackPanel>

        <!-- 빠른 삽입 팔레트 -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Padding="6"
                Margin="0,0,0,8">
            <StackPanel x:Name="QuickPanel" Orientation="Horizontal">
                <!-- 코드비하인드에서 채움 -->
            </StackPanel>
        </Border>

        <!-- LaTeX 소스 입력 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="LaTeX 소스" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Grid.Row="1" x:Name="SourceText"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="13"
                     TextChanged="OnSourceChanged" />
        </Grid>

        <TextBlock Grid.Row="3" Text="미리보기 (현 단계: 원본 텍스트 표시 — 정식 렌더러는 추후)"
                   Foreground="{DynamicResource OnSurfaceMuted}"
                   Margin="0,8,0,4" />

        <!-- 미리보기 -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock x:Name="PreviewText"
                           FontFamily="Cambria Math, Cambria, Consolas, monospace"
                           FontSize="18"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="삽입(_I)"
                    Width="96" Height="32"
                    Click="OnInsertClick"
                    IsDefault="True"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="96" Height="32"
                    Click="OnCloseClick"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
