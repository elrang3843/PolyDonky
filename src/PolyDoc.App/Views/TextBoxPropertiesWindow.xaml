<Window x:Class="PolyDoc.App.Views.TextBoxPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="글상자 속성"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="16">

        <!-- 테두리 색 -->
        <TextBlock Text="테두리 색 (hex, 예: #000000)" Margin="0,0,0,4" />
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtBorderColor"
                     Grid.Column="0"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}"
                     TextChanged="OnBorderColorChanged" />
            <Border x:Name="BorderColorPreview"
                    Grid.Column="2"
                    Height="26"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="1"
                    Background="Black" />
        </Grid>

        <!-- 테두리 두께 -->
        <TextBlock Text="테두리 두께 (pt)" Margin="0,0,0,4" />
        <TextBox x:Name="TxtBorderThickness"
                 Margin="0,0,0,12"
                 Padding="4,3"
                 Background="{DynamicResource SurfaceAlt}"
                 Foreground="{DynamicResource OnSurface}"
                 BorderBrush="{DynamicResource Divider}" />

        <!-- 배경색 -->
        <TextBlock Text="배경색 (hex, 예: #FFFFFF, 비우면 투명)" Margin="0,0,0,4" />
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtBackgroundColor"
                     Grid.Column="0"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}"
                     TextChanged="OnBackgroundColorChanged" />
            <Border x:Name="BackgroundColorPreview"
                    Grid.Column="2"
                    Height="26"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="1"
                    Background="White" />
        </Grid>

        <!-- OK / 취소 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인" Width="72" Padding="0,4"
                    IsDefault="True"
                    Background="{DynamicResource Primary}"
                    Foreground="{DynamicResource OnPrimary}"
                    Margin="0,0,8,0"
                    Click="OnOk" />
            <Button Content="취소" Width="72" Padding="0,4"
                    IsCancel="True"
                    Background="{DynamicResource SurfaceAlt}"
                    Foreground="{DynamicResource OnSurface}"
                    Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>
