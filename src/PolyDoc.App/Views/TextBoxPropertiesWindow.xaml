<Window x:Class="PolyDoc.App.Views.TextBoxPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="글상자 속성"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="16">

        <!-- ── 모양 ── -->
        <TextBlock Text="모양" FontWeight="SemiBold" Margin="0,0,0,6" />
        <ComboBox x:Name="CboShape"
                  Margin="0,0,0,8"
                  Background="{DynamicResource SurfaceAlt}"
                  Foreground="{DynamicResource OnSurface}"
                  BorderBrush="{DynamicResource Divider}"
                  SelectionChanged="OnShapeChanged">
            <ComboBoxItem Content="사각형" />
            <ComboBoxItem Content="말풍선" />
            <ComboBoxItem Content="구름풍선" />
            <ComboBoxItem Content="가시풍선" />
            <ComboBoxItem Content="번개상자" />
        </ComboBox>

        <!-- ── 말풍선: 꼬리 방향 (8방향 그리드) ── -->
        <Grid x:Name="PnlSpeech" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="꼬리 방향" VerticalAlignment="Center" />
            <UniformGrid Grid.Column="1" Rows="3" Columns="3" Width="120"
                         HorizontalAlignment="Left">
                <RadioButton x:Name="RbSpeechTL" GroupName="SpeechDir" Tag="TopLeft"     Content="↖" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechT"  GroupName="SpeechDir" Tag="Top"         Content="↑" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechTR" GroupName="SpeechDir" Tag="TopRight"    Content="↗" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechL"  GroupName="SpeechDir" Tag="Left"        Content="←" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Border /> <!-- center placeholder -->
                <RadioButton x:Name="RbSpeechR"  GroupName="SpeechDir" Tag="Right"       Content="→" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechBL" GroupName="SpeechDir" Tag="BottomLeft"  Content="↙" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechB"  GroupName="SpeechDir" Tag="Bottom"      Content="↓" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <RadioButton x:Name="RbSpeechBR" GroupName="SpeechDir" Tag="BottomRight" Content="↘" Padding="6,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            </UniformGrid>
        </Grid>

        <!-- ── 구름풍선: 뭉게 개수 ── -->
        <Grid x:Name="PnlCloud" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="뭉게 개수 (6~32)" VerticalAlignment="Center" />
            <TextBox x:Name="TxtCloudPuffs"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}" />
        </Grid>

        <!-- ── 가시풍선: 가시 개수 ── -->
        <Grid x:Name="PnlSpiky" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="가시 개수 (5~24)" VerticalAlignment="Center" />
            <TextBox x:Name="TxtSpikeCount"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}" />
        </Grid>

        <!-- ── 번개상자: 꺽임 개수 ── -->
        <Grid x:Name="PnlLightning" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="꺽임 개수 (1~5)" VerticalAlignment="Center" />
            <TextBox x:Name="TxtLightningBends"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}" />
        </Grid>

        <!-- ── 테두리 ── -->
        <TextBlock Text="테두리" FontWeight="SemiBold" Margin="0,0,0,6" />

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="색 (hex)" VerticalAlignment="Center" />
            <TextBox x:Name="TxtBorderColor"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}"
                     TextChanged="OnBorderColorChanged" />
            <Button x:Name="BtnBorderColorPick"
                    Grid.Column="3"
                    Height="26"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="1"
                    ToolTip="색상 선택..."
                    Click="OnBorderColorPickClick"
                    Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="두께 (pt)" VerticalAlignment="Center" />
            <TextBox x:Name="TxtBorderThickness"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}" />
        </Grid>

        <!-- ── 배경색 ── -->
        <TextBlock Text="배경" FontWeight="SemiBold" Margin="0,0,0,6" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="색 (hex, 빈 칸=투명)" VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBox x:Name="TxtBackgroundColor"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}"
                     TextChanged="OnBackgroundColorChanged" />
            <Button x:Name="BtnBackgroundColorPick"
                    Grid.Column="3"
                    Height="26"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="1"
                    ToolTip="색상 선택..."
                    Click="OnBackgroundColorPickClick"
                    Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── 안쪽 여백 ── -->
        <TextBlock Text="안쪽 여백 (mm)" FontWeight="SemiBold" Margin="0,0,0,6" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="위" HorizontalAlignment="Center" Margin="0,0,0,2" />
                <TextBox x:Name="TxtPaddingTop"
                         Padding="4,3"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         TextAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="아래" HorizontalAlignment="Center" Margin="0,0,0,2" />
                <TextBox x:Name="TxtPaddingBottom"
                         Padding="4,3"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         TextAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="왼쪽" HorizontalAlignment="Center" Margin="0,0,0,2" />
                <TextBox x:Name="TxtPaddingLeft"
                         Padding="4,3"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         TextAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="6">
                <TextBlock Text="오른쪽" HorizontalAlignment="Center" Margin="0,0,0,2" />
                <TextBox x:Name="TxtPaddingRight"
                         Padding="4,3"
                         Background="{DynamicResource SurfaceAlt}"
                         Foreground="{DynamicResource OnSurface}"
                         BorderBrush="{DynamicResource Divider}"
                         TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ── 정렬 ── -->
        <TextBlock Text="정렬" FontWeight="SemiBold" Margin="0,0,0,6" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="가로" VerticalAlignment="Center" />
            <ComboBox x:Name="CboHAlign"
                      Grid.Column="1"
                      Background="{DynamicResource SurfaceAlt}"
                      Foreground="{DynamicResource OnSurface}"
                      BorderBrush="{DynamicResource Divider}">
                <ComboBoxItem Content="왼쪽" />
                <ComboBoxItem Content="가운데" />
                <ComboBoxItem Content="오른쪽" />
                <ComboBoxItem Content="양쪽" />
            </ComboBox>
            <TextBlock Grid.Column="3" Text="세로" VerticalAlignment="Center"
                       HorizontalAlignment="Right" Margin="0,0,6,0" />
            <ComboBox x:Name="CboVAlign"
                      Grid.Column="4"
                      Background="{DynamicResource SurfaceAlt}"
                      Foreground="{DynamicResource OnSurface}"
                      BorderBrush="{DynamicResource Divider}">
                <ComboBoxItem Content="위" />
                <ComboBoxItem Content="가운데" />
                <ComboBoxItem Content="아래" />
            </ComboBox>
        </Grid>

        <!-- ── 회전 ── -->
        <TextBlock Text="회전" FontWeight="SemiBold" Margin="0,0,0,6" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="각도 (°, -360~360)" VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBox x:Name="TxtRotationAngle"
                     Grid.Column="1"
                     Padding="4,3"
                     Background="{DynamicResource SurfaceAlt}"
                     Foreground="{DynamicResource OnSurface}"
                     BorderBrush="{DynamicResource Divider}" />
        </Grid>

        <!-- ── 글자 방향 ── -->
        <TextBlock Text="글자 방향" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CboTextOrientation" Grid.Column="0"
                      Background="{DynamicResource SurfaceAlt}"
                      Foreground="{DynamicResource OnSurface}"
                      BorderBrush="{DynamicResource Divider}">
                <ComboBoxItem Content="가로 쓰기" />
                <ComboBoxItem Content="세로 쓰기 (모델만)" />
            </ComboBox>
            <ComboBox x:Name="CboTextProgression" Grid.Column="2"
                      Background="{DynamicResource SurfaceAlt}"
                      Foreground="{DynamicResource OnSurface}"
                      BorderBrush="{DynamicResource Divider}">
                <ComboBoxItem Content="오른쪽으로 진행" />
                <ComboBoxItem Content="왼쪽으로 진행" />
            </ComboBox>
        </Grid>

        <!-- ── 확인 / 취소 ── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인" Width="72" Padding="0,4"
                    IsDefault="True"
                    Background="{DynamicResource Primary}"
                    Foreground="{DynamicResource OnPrimary}"
                    Margin="0,0,8,0"
                    Click="OnOk" />
            <Button Content="취소" Width="72" Padding="0,4"
                    IsCancel="True"
                    Background="{DynamicResource SurfaceAlt}"
                    Foreground="{DynamicResource OnSurface}"
                    Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>
