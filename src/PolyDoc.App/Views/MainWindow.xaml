<Window x:Class="PolyDoc.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PolyDoc.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        MinWidth="640" MinHeight="480"
        FontFamily="{StaticResource UiFont}"
        Background="{StaticResource Surface}"
        Foreground="{StaticResource OnSurface}"
        AllowDrop="True"
        Drop="OnDrop"
        DragOver="OnDragOver">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Modifiers="Control+Shift" Key="S" Command="{Binding SaveAsCommand}" />
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding FindReplaceCommand}" />
        <KeyBinding Modifiers="Control" Key="H" Command="{Binding FindReplaceCommand}" />
    </Window.InputBindings>

    <DockPanel LastChildFill="True">

        <!-- 메뉴 바 -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource SurfaceAlt}">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="새 파일(_N)" Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="불러오기(_O)..." Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="저장(_S)" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="다른 이름으로 저장(_A)..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="미리보기(_V)" IsEnabled="False" />
                <MenuItem Header="인쇄(_P)..." IsEnabled="False" InputGestureText="Ctrl+P" />
                <Separator />
                <MenuItem Header="닫기(_C)" IsEnabled="False" />
                <MenuItem Header="종료(_X)" Command="{Binding ExitCommand}" InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem Header="편집(_E)">
                <MenuItem Header="복사(_C)" Command="ApplicationCommands.Copy" />
                <MenuItem Header="잘라내기(_T)" Command="ApplicationCommands.Cut" />
                <MenuItem Header="붙여넣기(_P)" Command="ApplicationCommands.Paste" />
                <MenuItem Header="지우기(_D)" Command="ApplicationCommands.Delete" />
                <Separator />
                <MenuItem Header="찾기/바꾸기(_F)..." Command="{Binding FindReplaceCommand}" InputGestureText="Ctrl+F" />
                <Separator />
                <MenuItem Header="문서 정보(_I)..." IsEnabled="False" />
            </MenuItem>

            <MenuItem Header="입력(_I)">
                <MenuItem Header="글상자(_T)" IsEnabled="False" />
                <MenuItem Header="표(_B)" IsEnabled="False" />
                <MenuItem Header="그래프(_G)" IsEnabled="False" />
                <MenuItem Header="특수문자(_S)" IsEnabled="False" />
                <MenuItem Header="수식(_E)" IsEnabled="False" />
                <MenuItem Header="이모지(_M)" IsEnabled="False" />
                <MenuItem Header="도형(_H)" IsEnabled="False" />
                <MenuItem Header="그림(_P)" IsEnabled="False" />
                <MenuItem Header="사인(_N)" IsEnabled="False" />
            </MenuItem>

            <MenuItem Header="서식(_R)">
                <MenuItem Header="글자 서식(_F)" IsEnabled="False" />
                <MenuItem Header="문단 서식(_P)" IsEnabled="False" />
                <MenuItem Header="페이지 서식(_G)" IsEnabled="False" />
            </MenuItem>

            <MenuItem Header="도구(_T)">
                <MenuItem Header="설정(_O)..." Command="{Binding SettingsCommand}" />
                <MenuItem Header="사전(_D)" IsEnabled="False" />
                <MenuItem Header="맞춤법 검사(_S)" IsEnabled="False" />
                <MenuItem Header="사인 만들기(_M)..." IsEnabled="False" />
            </MenuItem>

            <MenuItem Header="도움말(_H)">
                <MenuItem Header="사용 방법(_M)" IsEnabled="False" />
                <MenuItem Header="라이선스(_L)" IsEnabled="False" />
                <Separator />
                <MenuItem Header="PolyDoc 정보(_A)" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- 상태 바 — 좌측: 상태 메시지 (가변 너비) / 우측: 파일경로·메모리·Insert·Caps·Num 고정 그룹.
             ItemsPanel 을 DockPanel 로 교체하고 상태 메시지만 Left dock, 나머지는 Right dock 으로 우측에 모은다.
             자식 순서대로 우측에서부터 stacking 되므로 XAML 작성 순서 = 시각상 좌→우. -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource SurfaceAlt}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch" LastChildFill="True" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- 우측 그룹: NumLock 이 가장 우측 -->
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock Text="{Binding NumLockText}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="Num Lock"
                           MinWidth="40" TextAlignment="Center"
                           FontFamily="Consolas, D2Coding" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock Text="{Binding CapsLockText}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="Caps Lock"
                           MinWidth="40" TextAlignment="Center"
                           FontFamily="Consolas, D2Coding" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock Text="{Binding InsertModeText}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="Insert 키로 삽입/수정 토글"
                           MinWidth="40" TextAlignment="Center" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock Text="{Binding MemoryUsage}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="이 문서의 데이터 크기 (텍스트 + 이미지 + opaque)"
                           MinWidth="80" TextAlignment="Right" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock Text="{Binding CurrentFilePath}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="{Binding CurrentFilePath}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="600" />
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" />

            <!-- 좌측 — 가변 너비. LastChildFill=True 로 남은 가로 공간을 모두 차지. -->
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource OnSurfaceMuted}"
                           ToolTip="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
        </StatusBar>

        <!-- 본문 영역 — Phase B 폴리싱: RichTextBox + FlowDocument 로 서식 표시·편집.
             RichTextBox.Document 는 DependencyProperty 가 아니라 code-behind 에서 ViewModel 의
             FlowDocument 변경을 받아 동기화한다. TextChanged 는 dirty 마킹용. -->
        <Border Margin="12" BorderBrush="{StaticResource Divider}" BorderThickness="1">
            <RichTextBox x:Name="BodyEditor"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsDocumentEnabled="True"
                         SpellCheck.IsEnabled="False"
                         Padding="12"
                         BorderThickness="0"
                         Background="{StaticResource Surface}"
                         Foreground="{StaticResource OnSurface}" />
        </Border>

    </DockPanel>
</Window>
