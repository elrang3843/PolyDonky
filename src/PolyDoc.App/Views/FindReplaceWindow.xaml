<Window x:Class="PolyDoc.App.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding FindReplaceTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 찾기 -->
        <Label Grid.Row="0" Grid.Column="0"
               Content="{Binding FindReplaceFind, Source={x:Static svc:LocalizedStrings.Instance}}"
               Target="{Binding ElementName=FindBox}"
               VerticalAlignment="Center" />
        <TextBox x:Name="FindBox"
                 Grid.Row="0" Grid.Column="1"
                 Padding="4,3"
                 KeyDown="OnKeyDown" />

        <!-- 바꾸기 -->
        <Label Grid.Row="2" Grid.Column="0"
               Content="{Binding FindReplaceReplace, Source={x:Static svc:LocalizedStrings.Instance}}"
               Target="{Binding ElementName=ReplaceBox}"
               VerticalAlignment="Center" />
        <TextBox x:Name="ReplaceBox"
                 Grid.Row="2" Grid.Column="1"
                 Padding="4,3"
                 KeyDown="OnKeyDown" />

        <!-- 옵션 -->
        <CheckBox x:Name="CaseSensitiveBox"
                  Grid.Row="4" Grid.Column="1"
                  Content="{Binding FindReplaceCaseSensitive, Source={x:Static svc:LocalizedStrings.Instance}}"
                  VerticalAlignment="Center" />

        <!-- 상태 메시지 -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Foreground="{DynamicResource OnSurfaceMuted}"
                   FontSize="11"
                   MinHeight="16"
                   TextWrapping="Wrap" />

        <!-- 버튼 -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{Binding FindReplaceFindNext, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5"
                    IsDefault="True"
                    Click="OnFindNext" />
            <Button Content="{Binding FindReplaceReplaceOne, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" Margin="8,0,0,0"
                    Click="OnReplace" />
            <Button Content="{Binding FindReplaceReplaceAll, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" Margin="8,0,0,0"
                    Click="OnReplaceAll" />
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" Margin="8,0,0,0"
                    IsCancel="True"
                    Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
