<Window x:Class="PolyDoc.App.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="찾기 / 바꾸기"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: 찾기 -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />  <!-- 2: 바꾸기 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 4: 대소문자 -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />  <!-- 6: 상태 메시지 -->
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />  <!-- 8: 버튼 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 찾기 -->
        <Label Grid.Row="0" Grid.Column="0" Content="찾기(_F):"
               Target="{Binding ElementName=FindBox}"
               VerticalAlignment="Center" />
        <TextBox x:Name="FindBox"
                 Grid.Row="0" Grid.Column="1"
                 Padding="4,3"
                 KeyDown="OnKeyDown" />

        <!-- 바꾸기 -->
        <Label Grid.Row="2" Grid.Column="0" Content="바꾸기(_R):"
               Target="{Binding ElementName=ReplaceBox}"
               VerticalAlignment="Center" />
        <TextBox x:Name="ReplaceBox"
                 Grid.Row="2" Grid.Column="1"
                 Padding="4,3"
                 KeyDown="OnKeyDown" />

        <!-- 옵션 -->
        <CheckBox x:Name="CaseSensitiveBox"
                  Grid.Row="4" Grid.Column="1"
                  Content="대소문자 구분(_C)"
                  VerticalAlignment="Center" />

        <!-- 상태 메시지 -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Foreground="{DynamicResource OnSurfaceMuted}"
                   FontSize="11"
                   MinHeight="16"
                   TextWrapping="Wrap" />

        <!-- 버튼 -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="다음 찾기(_N)"
                    Padding="12,5"
                    IsDefault="True"
                    Click="OnFindNext" />
            <Button Content="바꾸기(_E)"
                    Padding="12,5" Margin="8,0,0,0"
                    Click="OnReplace" />
            <Button Content="모두 바꾸기(_A)"
                    Padding="12,5" Margin="8,0,0,0"
                    Click="OnReplaceAll" />
            <Button Content="닫기"
                    Padding="12,5" Margin="8,0,0,0"
                    IsCancel="True"
                    Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
