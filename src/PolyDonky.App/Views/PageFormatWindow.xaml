<Window x:Class="PolyDonky.App.Views.PageFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDonky.App.Services"
        Title="{Binding PageFormatTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="700" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="12">

        <!-- 본문: 좌(탭) / 우(미리보기) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>

            <!-- ── 탭 패널 ── -->
            <TabControl x:Name="MainTabControl"
                        Grid.Column="0"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Divider}">

                <!-- ── 용지 탭 ── -->
                <TabItem Header="{Binding PageFormatPaperTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <StackPanel Margin="10,8">

                        <!-- 용지 크기 -->
                        <TextBlock Text="{Binding PageFormatSizeLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="CboSize"
                                  Background="{DynamicResource SurfaceAlt}"
                                  Foreground="{DynamicResource OnSurface}"
                                  BorderBrush="{DynamicResource Divider}"
                                  Margin="0,0,0,10"
                                  SelectionChanged="OnSizeChanged" />

                        <!-- 사용자 정의 치수 -->
                        <Grid x:Name="PanelCustomSize" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding PageFormatWidthLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           Margin="0,0,0,2" />
                                <TextBox x:Name="TxtWidth" Padding="4,3"
                                         Background="{DynamicResource SurfaceAlt}"
                                         Foreground="{DynamicResource OnSurface}"
                                         BorderBrush="{DynamicResource Divider}"
                                         TextChanged="OnDimensionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding PageFormatHeightLabel, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           Margin="0,0,0,2" />
                                <TextBox x:Name="TxtHeight" Padding="4,3"
                                         Background="{DynamicResource SurfaceAlt}"
                                         Foreground="{DynamicResource OnSurface}"
                                         BorderBrush="{DynamicResource Divider}"
                                         TextChanged="OnDimensionChanged" />
                            </StackPanel>
                        </Grid>

                        <!-- 방향 -->
                        <TextBlock Text="{Binding PageFormatOrientation, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="RbPortrait"
                                         Content="{Binding PageFormatPortrait, Source={x:Static svc:LocalizedStrings.Instance}}"
                                         GroupName="Orientation" IsChecked="True"
                                         Margin="0,0,16,0"
                                         Checked="OnOrientationChanged" />
                            <RadioButton x:Name="RbLandscape"
                                         Content="{Binding PageFormatLandscape, Source={x:Static svc:LocalizedStrings.Instance}}"
                                         GroupName="Orientation"
                                         Checked="OnOrientationChanged" />
                        </StackPanel>

                        <!-- 글자 방향 — 추후 지원 예정 -->
                        <TextBlock Text="글자 방향 (추후 지원 예정)" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceDisabled}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,10" IsEnabled="False" Opacity="0.45">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CboTextOrientation" Grid.Column="0"
                                      Background="{DynamicResource SurfaceAlt}"
                                      Foreground="{DynamicResource OnSurface}"
                                      BorderBrush="{DynamicResource Divider}"
                                      SelectionChanged="OnTextDirectionChanged">
                                <ComboBoxItem Content="가로 쓰기" />
                                <ComboBoxItem Content="세로 쓰기" />
                            </ComboBox>
                            <ComboBox x:Name="CboTextProgression" Grid.Column="2"
                                      Background="{DynamicResource SurfaceAlt}"
                                      Foreground="{DynamicResource OnSurface}"
                                      BorderBrush="{DynamicResource Divider}"
                                      SelectionChanged="OnTextDirectionChanged">
                                <ComboBoxItem Content="오른쪽으로 진행" />
                                <ComboBoxItem Content="왼쪽으로 진행" />
                            </ComboBox>
                        </Grid>

                        <!-- 용지 색상 -->
                        <TextBlock Text="{Binding PageFormatPaperColor, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   FontWeight="SemiBold" Margin="0,0,0,4" />
                        <DockPanel>
                            <CheckBox x:Name="ChkDefaultColor"
                                      DockPanel.Dock="Bottom"
                                      Content="{Binding PageFormatPaperColorDefault, Source={x:Static svc:LocalizedStrings.Instance}}"
                                      Margin="0,4,0,0"
                                      Checked="OnDefaultColorChanged" Unchecked="OnDefaultColorChanged" />
                            <Border x:Name="PaperColorSwatch"
                                    DockPanel.Dock="Right"
                                    Width="22" Height="22" Margin="6,0,0,0"
                                    BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnPaperColorSwatchClick" />
                            <TextBox x:Name="TxtPaperColor"
                                     Padding="4,3"
                                     Background="{DynamicResource SurfaceAlt}"
                                     Foreground="{DynamicResource OnSurface}"
                                     BorderBrush="{DynamicResource Divider}"
                                     TextChanged="OnPaperColorChanged" />
                        </DockPanel>

                    </StackPanel>
                </TabItem>

                <!-- ── 여백 탭 ── -->
                <TabItem Header="{Binding PageFormatMarginsTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <Grid Margin="10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding PageFormatMarginTop, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtMarginTop"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding PageFormatMarginBottom, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtMarginBottom"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{Binding PageFormatMarginLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtMarginLeft"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="6" Grid.Column="0"
                                   Text="{Binding PageFormatMarginRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TxtMarginRight"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="{Binding PageFormatMarginHeader, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="8" Grid.Column="1" x:Name="TxtMarginHeader"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <TextBlock Grid.Row="10" Grid.Column="0"
                                   Text="{Binding PageFormatMarginFooter, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="10" Grid.Column="1" x:Name="TxtMarginFooter"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnMarginChanged" />

                        <CheckBox  Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                                   x:Name="ChkShowMarginGuides"
                                   Content="{Binding PageFormatShowMarginGuides, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   Checked="OnShowMarginGuidesChanged"
                                   Unchecked="OnShowMarginGuidesChanged" />
                    </Grid>
                </TabItem>

                <!-- ── 레이아웃 탭 ── -->
                <TabItem Header="{Binding PageFormatLayoutTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <Grid Margin="10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding PageFormatColumns, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtColumns"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding PageFormatColumnGap, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtColumnGap"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{Binding PageFormatPageNumberStart, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtPageNumberStart"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <!-- ── 단 구분선 ── -->
                        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4"
                                  x:Name="ChkColumnDividerVisible"
                                  Content="{Binding PageFormatColumnDividerVisible, Source={x:Static svc:LocalizedStrings.Instance}}"
                                  Checked="OnDividerVisibleChanged"
                                  Unchecked="OnDividerVisibleChanged" />

                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="{Binding PageFormatColumnDividerColor, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="8" Grid.Column="1" x:Name="TxtColumnDividerColor"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnDividerColorChanged" />
                        <Button x:Name="BtnColumnDividerColorPick"
                                Grid.Row="8" Grid.Column="3"
                                Height="26"
                                BorderBrush="{DynamicResource Divider}"
                                BorderThickness="1"
                                Click="OnDividerColorPickClick"
                                Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Row="10" Grid.Column="0"
                                   Text="{Binding PageFormatColumnDividerThickness, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <TextBox   Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtColumnDividerThickness"
                                   Padding="4,3"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   TextChanged="OnLayoutChanged" />

                        <TextBlock Grid.Row="12" Grid.Column="0"
                                   Text="{Binding PageFormatColumnDividerStyle, Source={x:Static svc:LocalizedStrings.Instance}}"
                                   VerticalAlignment="Center" />
                        <ComboBox  Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="3" x:Name="CboColumnDividerStyle"
                                   Background="{DynamicResource SurfaceAlt}"
                                   Foreground="{DynamicResource OnSurface}"
                                   BorderBrush="{DynamicResource Divider}"
                                   SelectionChanged="OnDividerStyleChanged">
                            <ComboBoxItem Content="{Binding ColumnDividerStyleNone,   Source={x:Static svc:LocalizedStrings.Instance}}" />
                            <ComboBoxItem Content="{Binding ColumnDividerStyleSolid,  Source={x:Static svc:LocalizedStrings.Instance}}" />
                            <ComboBoxItem Content="{Binding ColumnDividerStyleDashed, Source={x:Static svc:LocalizedStrings.Instance}}" />
                            <ComboBoxItem Content="{Binding ColumnDividerStyleDotted, Source={x:Static svc:LocalizedStrings.Instance}}" />
                        </ComboBox>
                    </Grid>
                </TabItem>

                <!-- ── 머리말/꼬리말 탭 ── -->
                <TabItem x:Name="TabHeaderFooter"
                         Header="{Binding PageFormatHeaderFooterTab, Source={x:Static svc:LocalizedStrings.Instance}}">
                    <DockPanel Margin="10,8" LastChildFill="True">

                        <!-- 서식 툴바 -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource SurfaceVariant}"
                                BorderBrush="{DynamicResource Divider}"
                                BorderThickness="1"
                                Margin="0,0,0,8"
                                Padding="4,3">
                            <WrapPanel Orientation="Horizontal">
                                <ComboBox x:Name="CboHFFontFamily"
                                          Width="130" Height="22" Margin="1,0"
                                          IsEditable="True"
                                          ToolTip="{Binding PageFormatHFToolbarFontFamily, Source={x:Static svc:LocalizedStrings.Instance}}"
                                          SelectionChanged="OnHFFontFamilyChanged"
                                          LostFocus="OnHFFontFamilyLostFocus"/>
                                <Separator Margin="4,1"/>
                                <ToggleButton x:Name="BtnHFBold"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarBold, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFBold">
                                    <TextBlock Text="B" FontWeight="Bold"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFItalic"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarItalic, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFItalic">
                                    <TextBlock Text="I" FontStyle="Italic"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFUnderline"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarUnderline, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFUnderline">
                                    <TextBlock Text="U" TextDecorations="Underline"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFStrike"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarStrike, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFStrikethrough">
                                    <TextBlock Text="S" TextDecorations="Strikethrough"/>
                                </ToggleButton>
                                <Separator Margin="4,1"/>
                                <ComboBox x:Name="CboHFFontSize"
                                          Width="54" Height="22" Margin="1,0"
                                          IsEditable="True"
                                          ToolTip="{Binding PageFormatHFToolbarFontSize, Source={x:Static svc:LocalizedStrings.Instance}}"
                                          SelectionChanged="OnHFFontSizeChanged"
                                          LostFocus="OnHFFontSizeLostFocus"/>
                                <Separator Margin="4,1"/>
                                <Button x:Name="BtnHFFontColor"
                                        Width="26" Height="22" Margin="1,0"
                                        ToolTip="{Binding PageFormatHFToolbarColor, Source={x:Static svc:LocalizedStrings.Instance}}"
                                        Click="OnHFFontColor">
                                    <Grid Width="16" Height="14">
                                        <TextBlock Text="A" FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                                   Margin="0,0,0,3"/>
                                        <Rectangle x:Name="HFColorBar" Height="3"
                                                   VerticalAlignment="Bottom"
                                                   Fill="Black"/>
                                    </Grid>
                                </Button>
                                <Separator Margin="4,1"/>
                                <ToggleButton x:Name="BtnHFAlignLeft"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarAlignLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFAlignLeft">
                                    <TextBlock Text="≡" FontSize="11" HorizontalAlignment="Left"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFAlignCenter"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarAlignCenter, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFAlignCenter">
                                    <TextBlock Text="≡" FontSize="11" HorizontalAlignment="Center"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFAlignRight"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarAlignRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFAlignRight">
                                    <TextBlock Text="≡" FontSize="11" HorizontalAlignment="Right"/>
                                </ToggleButton>
                                <ToggleButton x:Name="BtnHFAlignJustify"
                                              Width="24" Height="22" Margin="1,0"
                                              ToolTip="{Binding PageFormatHFToolbarAlignJustify, Source={x:Static svc:LocalizedStrings.Instance}}"
                                              Click="OnHFAlignJustify">
                                    <TextBlock Text="≡" FontSize="11"/>
                                </ToggleButton>
                                <Separator Margin="4,1"/>
                                <ComboBox x:Name="CboHFToken"
                                          Width="136" Height="22" Margin="1,0"/>
                                <Button Content="{Binding PageFormatHFTokenInsert, Source={x:Static svc:LocalizedStrings.Instance}}"
                                        Width="46" Height="22" Margin="2,0,0,0"
                                        Click="OnInsertToken"/>
                            </WrapPanel>
                        </Border>

                        <!-- 스크롤 가능 콘텐츠 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- 머리말 섹션 -->
                                <TextBlock Text="{Binding PageFormatHeaderGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource OnSurface}"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding PageFormatHFLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbHeaderLeft" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding PageFormatHFCenter, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbHeaderCenter" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{Binding PageFormatHFRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbHeaderRight" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,12,0,12" Background="{DynamicResource Divider}"/>

                                <!-- 꼬리말 섹션 -->
                                <TextBlock Text="{Binding PageFormatFooterGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource OnSurface}"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding PageFormatHFLeft, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbFooterLeft" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding PageFormatHFCenter, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbFooterCenter" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{Binding PageFormatHFRight, Source={x:Static svc:LocalizedStrings.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource OnSurfaceMuted}" Margin="0,0,0,2"/>
                                        <RichTextBox x:Name="RtbFooterRight" Height="56"
                                                     FontSize="12" AcceptsReturn="True"
                                                     SpellCheck.IsEnabled="False"
                                                     Background="{DynamicResource SurfaceAlt}"
                                                     Foreground="{DynamicResource OnSurface}"
                                                     BorderBrush="{DynamicResource Divider}"
                                                     GotFocus="OnRtbGotFocus"
                                                     SelectionChanged="OnRtbSelectionChanged"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 토큰 힌트 -->
                                <TextBlock Text="{Binding PageFormatHFTokenHint, Source={x:Static svc:LocalizedStrings.Instance}}"
                                           FontSize="10"
                                           Foreground="{DynamicResource OnSurfaceMuted}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>

            </TabControl>

            <!-- ── 미리보기 ── -->
            <GroupBox Grid.Column="2" Padding="6,4">
                <GroupBox.Header>
                    <TextBlock Text="{Binding PageFormatPreviewGroup, Source={x:Static svc:LocalizedStrings.Instance}}"
                               FontWeight="SemiBold" />
                </GroupBox.Header>
                <Border Background="{DynamicResource SurfaceAlt}"
                        BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                        Padding="6">
                    <Canvas x:Name="PreviewCanvas" Width="148" Height="200"
                            Background="Transparent" />
                </Border>
            </GroupBox>

        </Grid>

        <!-- 하단 버튼 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인" Padding="16,5" IsDefault="True" Click="OnOk" />
            <Button Content="취소" Padding="16,5" Margin="8,0,0,0" IsCancel="True" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>
