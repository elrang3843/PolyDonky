<Window x:Class="PolyDonky.App.Views.CellPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:PolyDonky.App.Controls"
        Title="셀 속성"
        Width="400" Height="420"
        MinWidth="360" MinHeight="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 배경색 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 텍스트 정렬 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 여백 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 테두리 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 배경색 ─────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="배경색" Padding="8,4,8,8">
            <ctrl:ColorPickerBox x:Name="BgColorPicker" AllowEmpty="True" />
        </GroupBox>

        <!-- ── 텍스트 정렬 ─────────────────────────────────────────────── -->
        <GroupBox Grid.Row="2" Header="텍스트 정렬" Padding="8,4,8,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="AlignLeftRadio"    Content="왼쪽(_L)"    IsChecked="True" Margin="0,0,12,0" />
                <RadioButton x:Name="AlignCenterRadio"  Content="가운데(_C)"                    Margin="0,0,12,0" />
                <RadioButton x:Name="AlignRightRadio"   Content="오른쪽(_R)"                    Margin="0,0,12,0" />
                <RadioButton x:Name="AlignJustifyRadio" Content="양쪽 맞춤(_J)"                 Margin="0,0,0,0" />
            </StackPanel>
        </GroupBox>

        <!-- ── 여백 (mm) ───────────────────────────────────────────────── -->
        <GroupBox Grid.Row="4" Header="여백 (mm)" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="52" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="위:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="PadTopBox"    Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="아래:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="PadBottomBox" Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="왼쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PadLeftBox"   Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Grid.Column="3" Text="오른쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="PadRightBox"  Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 테두리 ───────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="6" Header="테두리" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="두께:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="BorderThicknessBox"
                           Text="0.75" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text=" pt" VerticalAlignment="Center"
                           Foreground="{DynamicResource OnSurfaceMuted}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="색상:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ctrl:ColorPickerBox x:Name="BorderColorPicker"
                                     Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                     Margin="32,0,0,0"
                                     AllowEmpty="False" />
            </Grid>
        </GroupBox>

        <!-- ── 버튼 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인(_O)"
                    Width="88" Height="30"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="30"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
