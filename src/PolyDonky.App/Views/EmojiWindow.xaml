<Window x:Class="PolyDonky.App.Views.EmojiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이모지"
        Width="780" Height="560"
        MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 검색 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="검색:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="SearchInput"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchChanged" />
            <TextBlock Grid.Column="2" Text="  키워드(예: done, heart, save, sparkle)"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       VerticalAlignment="Center" Margin="6,0,0,0" />
        </Grid>

        <!-- 좌: 카테고리 / 우: 그리드 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" x:Name="CategoryList"
                     SelectionChanged="OnCategoryChanged"
                     BorderBrush="{DynamicResource OnSurfaceMuted}" />

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource OnSurfaceMuted}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="EmojiGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="56" Height="56"
                                        Margin="3"
                                        Padding="4"
                                        Click="OnEmojiButtonClick"
                                        MouseDoubleClick="OnEmojiButtonDoubleClick"
                                        ToolTip="{Binding Tooltip}"
                                        Tag="{Binding Key}">
                                    <Image Source="{Binding ImageSource}"
                                           Stretch="Uniform" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 미리보기 -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Margin="0,8,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image x:Name="PreviewImage"
                       Grid.Column="0"
                       Width="64" Height="64"
                       Stretch="Uniform" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText"
                               Text="이모지를 선택하세요"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="KeyText"
                               Foreground="{DynamicResource OnSurfaceMuted}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 크기 선택 + 버튼 -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <TextBlock Text="크기:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="SizeCombo"
                          Width="100"
                          VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="삽입(_I)"
                        Width="96" Height="32"
                        Click="OnInsertClick"
                        IsDefault="True"
                        Margin="0,0,8,0" />
                <Button Content="닫기"
                        Width="96" Height="32"
                        Click="OnCloseClick"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
