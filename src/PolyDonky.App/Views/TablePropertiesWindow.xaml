<Window x:Class="PolyDonky.App.Views.TablePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:PolyDonky.App.Controls"
        Title="표 속성"
        Width="430" SizeToContent="Height"
        MinWidth="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 배치 모드 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 오버레이 위치 (조건부) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 표 정렬 (Block 모드 전용) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 배경색 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 기본 셀 안여백 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 바깥 여백 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 표 외곽선 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 배치 모드 ───────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="배치 방식" Padding="8,4,8,8">
            <WrapPanel>
                <RadioButton x:Name="WrapBlockRadio"
                             Content="본문 흐름(_B)"
                             IsChecked="True"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapFrontRadio"
                             Content="텍스트 위(_F)"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapBehindRadio"
                             Content="텍스트 아래(_D)"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapFixedRadio"
                             Content="위치 고정(_X)"
                             Click="OnWrapModeChanged" />
            </WrapPanel>
        </GroupBox>

        <!-- ── 오버레이 위치 — InFrontOfText/BehindText/Fixed 모드 전용 ── -->
        <GroupBox x:Name="GrpOverlayPos" Grid.Row="2" Header="오버레이 위치 (mm, 페이지 좌상단 기준)"
                  Padding="8,4,8,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="1" x:Name="OverlayXBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="3" Text="Y:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="4" x:Name="OverlayYBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 표 정렬 (Block 모드 전용) ─────────────────────────────────── -->
        <GroupBox x:Name="GrpHAlign" Grid.Row="4" Header="표 정렬" Padding="8,4,8,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="AlignLeftRadio"   Content="왼쪽(_L)"   IsChecked="True" Margin="0,0,12,0" />
                <RadioButton x:Name="AlignCenterRadio" Content="가운데(_C)"                   Margin="0,0,12,0" />
                <RadioButton x:Name="AlignRightRadio"  Content="오른쪽(_R)"                   />
            </StackPanel>
        </GroupBox>

        <!-- ── 표 배경색 ─────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="6" Header="표 배경색" Padding="8,4,8,8">
            <ctrl:ColorPickerBox x:Name="BgColorPicker" AllowEmpty="True" />
        </GroupBox>

        <!-- ── 기본 셀 안여백 (mm) ─────────────────────────────────────── -->
        <GroupBox Grid.Row="8" Header="기본 셀 안여백 (mm) — 개별 셀 설정이 없을 때 사용" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="위:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CellPadTopBox"
                           Text="1.0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="아래:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="CellPadBottomBox"
                           Text="1.0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="왼쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="CellPadLeftBox"
                           Text="1.5" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="오른쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="CellPadRightBox"
                           Text="1.5" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 바깥 여백 (mm) ─────────────────────────────────────────── -->
        <GroupBox Grid.Row="10" Header="바깥 여백 (mm)" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="위:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="OuterMarginTopBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="아래:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="OuterMarginBottomBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="왼쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="OuterMarginLeftBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="오른쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="OuterMarginRightBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 표 외곽선 ──────────────────────────────────────────────── -->
        <GroupBox Grid.Row="12" Header="표 외곽선" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="두께:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="BorderThicknessBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center"
                           ToolTip="0이면 외곽선 없음" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text=" pt" VerticalAlignment="Center"
                           Foreground="{DynamicResource OnSurfaceMuted}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="색상:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ctrl:ColorPickerBox x:Name="BorderColorPicker"
                                     Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                     Margin="36,0,0,0"
                                     AllowEmpty="True" />
            </Grid>
        </GroupBox>

        <!-- ── 버튼 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인(_O)"
                    Width="88" Height="30"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="30"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
