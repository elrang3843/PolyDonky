<Window x:Class="PolyDonky.App.Views.TablePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="표 속성"
        Width="300" Height="180"
        MinWidth="260" MinHeight="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 표 정렬 -->
        <TextBlock Grid.Row="0" Text="표 정렬:" FontWeight="SemiBold" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,0,0">
            <RadioButton x:Name="AlignLeftRadio"   Content="왼쪽(_L)"    IsChecked="True"  Margin="0,0,12,0" />
            <RadioButton x:Name="AlignCenterRadio" Content="가운데(_C)"                     Margin="0,0,12,0" />
            <RadioButton x:Name="AlignRightRadio"  Content="오른쪽(_R)"                     Margin="0,0,0,0" />
        </StackPanel>

        <!-- 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인(_O)"
                    Width="88" Height="30"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="30"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
