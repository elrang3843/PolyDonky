<Window x:Class="PolyDonky.App.Views.ImagePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="그림 속성"
        Width="560" SizeToContent="Height"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 크기 -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="크기:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="너비" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="WidthBox" Width="70" VerticalContentAlignment="Center"
                     TextChanged="OnWidthChanged" />
            <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,16,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
            <TextBlock Text="높이" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="HeightBox" Width="70" VerticalContentAlignment="Center"
                     TextChanged="OnHeightChanged" />
            <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,16,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
            <CheckBox x:Name="LockRatioCheck" Content="비율 유지"
                      IsChecked="True" VerticalAlignment="Center" />
        </StackPanel>

        <!-- 정렬 -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="정렬:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <RadioButton x:Name="AlignLeft"   Content="왼쪽(_L)"   GroupName="Align" IsChecked="True" Margin="0,0,16,0" />
            <RadioButton x:Name="AlignCenter" Content="가운데(_C)" GroupName="Align" Margin="0,0,16,0" />
            <RadioButton x:Name="AlignRight"  Content="오른쪽(_R)" GroupName="Align" />
        </StackPanel>

        <!-- 텍스트 배치 (Wrap) -->
        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="배치:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
            <ComboBox x:Name="WrapCombo" Width="280"
                      VerticalContentAlignment="Center"
                      SelectionChanged="OnWrapModeChanged" />
            <!-- 오버레이 모드일 때만 활성: X/Y 위치 -->
            <TextBlock Text="X" VerticalAlignment="Center" Margin="16,0,4,0"
                       x:Name="OverlayXLabel" />
            <TextBox x:Name="OverlayXBox" Width="50" VerticalContentAlignment="Center" />
            <TextBlock Text="Y" VerticalAlignment="Center" Margin="8,0,4,0"
                       x:Name="OverlayYLabel" />
            <TextBox x:Name="OverlayYBox" Width="50" VerticalContentAlignment="Center" />
            <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       x:Name="OverlayMmLabel" />
        </StackPanel>

        <!-- 여백 -->
        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="여백:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="위" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="MarginTopBox" Width="60" VerticalContentAlignment="Center" />
            <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,20,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
            <TextBlock Text="아래" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="MarginBottomBox" Width="60" VerticalContentAlignment="Center" />
            <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
        </StackPanel>

        <!-- 테두리 -->
        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="테두리:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="색상" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="BorderColorBox" Width="80" VerticalContentAlignment="Center"
                     TextChanged="OnBorderColorChanged" />
            <Rectangle x:Name="BorderColorPreview"
                       Width="20" Height="20" Margin="6,0,20,0"
                       Stroke="{DynamicResource OnSurfaceMuted}" StrokeThickness="1" />
            <TextBlock Text="두께" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox x:Name="BorderThicknessBox" Width="56" VerticalContentAlignment="Center" />
            <TextBlock Text="pt" VerticalAlignment="Center" Margin="4,0,0,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
        </StackPanel>

        <!-- 설명 -->
        <TextBlock Grid.Row="10" Grid.Column="0"
                   Text="설명:" VerticalAlignment="Center" />
        <TextBox Grid.Row="10" Grid.Column="1"
                 x:Name="DescriptionBox" VerticalContentAlignment="Center" />

        <!-- 그림 제목 (캡션) -->
        <GroupBox Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                  Header="그림 제목" Margin="0,8,0,0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                          x:Name="ShowTitleCheck" Content="제목 표시"
                          Margin="4,2" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="텍스트:" VerticalAlignment="Center" />
                <TextBox x:Name="TitleTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                         Margin="4,2" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="글꼴:" VerticalAlignment="Center" />
                <TextBox x:Name="TitleFontBox" Grid.Row="2" Grid.Column="1" Margin="4,2" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="크기 (pt):" VerticalAlignment="Center" />
                <TextBox x:Name="TitleSizeBox" Grid.Row="2" Grid.Column="3" Margin="4,2" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="글자색:" VerticalAlignment="Center" />
                <TextBox x:Name="TitleColorBox" Grid.Row="3" Grid.Column="1" Margin="4,2" />
                <TextBlock Grid.Row="3" Grid.Column="2" Text="배경색:" VerticalAlignment="Center" />
                <TextBox x:Name="TitleBgColorBox" Grid.Row="3" Grid.Column="3" Margin="4,2" />

                <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                            Orientation="Horizontal" Margin="4,2">
                    <CheckBox x:Name="TitleBoldCheck"   Content="굵게"   VerticalAlignment="Center" Margin="0,0,8,0" />
                    <CheckBox x:Name="TitleItalicCheck" Content="기울임" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="배치:" VerticalAlignment="Center" />
                <ComboBox x:Name="TitlePositionCombo" Grid.Row="5" Grid.Column="1" Margin="4,2">
                    <ComboBoxItem Tag="Above">그림 위(외부)</ComboBoxItem>
                    <ComboBoxItem Tag="Below">그림 아래(외부)</ComboBoxItem>
                    <ComboBoxItem Tag="OverlayTop">그림 위에 겹침 — 상단</ComboBoxItem>
                    <ComboBoxItem Tag="OverlayMiddle">그림 위에 겹침 — 가운데</ComboBoxItem>
                    <ComboBoxItem Tag="OverlayBottom">그림 위에 겹침 — 하단</ComboBoxItem>
                </ComboBox>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="가로 정렬:" VerticalAlignment="Center" />
                <ComboBox x:Name="TitleHAlignCombo" Grid.Row="5" Grid.Column="3" Margin="4,2">
                    <ComboBoxItem Tag="Left">왼쪽</ComboBoxItem>
                    <ComboBoxItem Tag="Center">가운데</ComboBoxItem>
                    <ComboBoxItem Tag="Right">오른쪽</ComboBoxItem>
                </ComboBox>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="X 오프셋(mm):" VerticalAlignment="Center" />
                <TextBox x:Name="TitleOffsetXBox" Grid.Row="6" Grid.Column="1" Margin="4,2" />
                <TextBlock Grid.Row="6" Grid.Column="2" Text="Y 오프셋(mm):" VerticalAlignment="Center" />
                <TextBox x:Name="TitleOffsetYBox" Grid.Row="6" Grid.Column="3" Margin="4,2" />
            </Grid>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인"
                    Width="88" Height="32"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="32"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
