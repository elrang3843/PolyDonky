<Window x:Class="PolyDonky.App.Views.EmojiPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이모지 속성"
        Width="380" Height="200"
        MinWidth="320" MinHeight="180"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 크기 -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="크기:" VerticalAlignment="Center" />
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <ComboBox x:Name="SizeCombo" Width="130" VerticalContentAlignment="Center" />
            <TextBlock Text="pt" VerticalAlignment="Center" Margin="6,0,0,0"
                       Foreground="{DynamicResource OnSurfaceMuted}" />
        </StackPanel>

        <!-- 기준선 -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="기준선 정렬:" VerticalAlignment="Center" />
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="AlignCombo" Width="160"
                  HorizontalAlignment="Left"
                  VerticalContentAlignment="Center" />

        <!-- 버튼 -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인"
                    Width="88" Height="32"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="32"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
