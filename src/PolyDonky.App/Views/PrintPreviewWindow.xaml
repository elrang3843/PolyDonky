<Window x:Class="PolyDonky.App.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDonky.App.Services"
        Title="{Binding MenuFilePreview, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="960" Height="720"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/PolyDonky.ico"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}"
        Closed="OnWindowClosed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceVariant}"
                BorderBrush="{DynamicResource Outline}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <Button x:Name="PrintBtn"
                        DockPanel.Dock="Left"
                        Content="{Binding MenuFilePrint, Source={x:Static svc:LocalizedStrings.Instance}}"
                        Width="80" Height="28"
                        Margin="0,0,8,0"
                        Click="OnPrintClick" />

                <Button DockPanel.Dock="Right"
                        Content="{Binding MenuFileClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                        Width="64" Height="28"
                        IsCancel="True"
                        Click="OnCloseClick" />

                <!-- 줌 컨트롤 -->
                <Button DockPanel.Dock="Left"
                        Content="−"
                        Width="32" Height="28"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="8,0,0,0"
                        ToolTip="축소"
                        Click="OnZoomOutClick" />
                <Button DockPanel.Dock="Left"
                        Content="+"
                        Width="32" Height="28"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="2,0,0,0"
                        ToolTip="확대"
                        Click="OnZoomInClick" />
                <TextBlock x:Name="ZoomText"
                           DockPanel.Dock="Left"
                           Text="100%"
                           VerticalAlignment="Center"
                           Width="56"
                           TextAlignment="Center"
                           Margin="6,0,0,0"
                           Foreground="{DynamicResource OnSurface}"
                           FontSize="12" />
                <Button DockPanel.Dock="Left"
                        Content="쪽 맞춤"
                        Width="68" Height="28"
                        Margin="6,0,0,0"
                        ToolTip="페이지 전체가 보이게"
                        Click="OnFitPageClick" />
                <Button DockPanel.Dock="Left"
                        Content="폭 맞춤"
                        Width="68" Height="28"
                        Margin="2,0,12,0"
                        ToolTip="가로 폭에 맞춤"
                        Click="OnFitWidthClick" />

                <!-- 페이지 정보 레이블 -->
                <TextBlock x:Name="PageInfoText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource OnSurfaceMuted}"
                           FontSize="12" />
            </DockPanel>
        </Border>

        <!-- DocumentViewer — 기본 툴바는 숨기고 뷰어만 사용 -->
        <DocumentViewer x:Name="PreviewViewer"
                        Grid.Row="1">
            <DocumentViewer.Style>
                <Style TargetType="DocumentViewer">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DocumentViewer">
                                <Border Background="#FF404040">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DocumentViewer.Style>
        </DocumentViewer>

        <!-- 생성 중 스피너 -->
        <Border x:Name="LoadingOverlay"
                Grid.Row="1"
                Background="{DynamicResource Surface}"
                Visibility="Visible">
            <TextBlock Text="미리보기 생성 중..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       FontSize="14" />
        </Border>
    </Grid>
</Window>
