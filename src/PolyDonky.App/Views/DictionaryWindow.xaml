<Window x:Class="PolyDonky.App.Views.DictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDonky.App.Services"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding DictWindowTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="960" Height="680"
        MinWidth="560" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/PolyDonky.ico"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}"
        Closing="OnWindowClosing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 검색 바 -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceVariant}"
                BorderBrush="{DynamicResource Outline}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 사전 사이트 선택 -->
                <ComboBox x:Name="SiteCombo"
                          Grid.Column="0"
                          Width="160"
                          VerticalAlignment="Center"
                          SelectionChanged="OnSiteChanged" />

                <!-- 검색어 입력 -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         Height="28"
                         Padding="6,4"
                         FontSize="13"
                         KeyDown="OnSearchBoxKeyDown" />

                <!-- 검색 버튼 -->
                <Button x:Name="SearchBtn"
                        Grid.Column="4"
                        Content="{Binding DictWindowSearch, Source={x:Static svc:LocalizedStrings.Instance}}"
                        Width="64" Height="28"
                        Click="OnSearchClick" />
            </Grid>
        </Border>

        <!-- WebView2 영역 -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="WebView" />

            <!-- WebView2 로드 중 또는 런타임 없을 때 표시되는 오버레이 -->
            <Border x:Name="ErrorOverlay"
                    Visibility="Collapsed"
                    Background="{DynamicResource Surface}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <TextBlock x:Name="ErrorText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="24"
                           FontSize="13"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
            </Border>
        </Grid>
    </Grid>
</Window>
