<Window x:Class="PolyDonky.App.Views.ImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="그림 삽입"
        Width="620" Height="520"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 파일 선택 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="파일:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="FilePathBox"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Foreground="{DynamicResource OnSurfaceMuted}" />
            <Button Grid.Column="2" Content="찾아보기(_B)..."
                    Width="104" Height="32"
                    Click="OnBrowseClick"
                    Margin="8,0,0,0" />
        </Grid>

        <!-- 미리보기 -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Margin="0,0,0,8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="8" />
            </ScrollViewer>
        </Border>

        <!-- 크기 + 설명 -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 크기 행 -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="크기:" VerticalAlignment="Center" />
            <StackPanel Grid.Row="0" Grid.Column="1"
                        Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="너비" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox x:Name="WidthBox"
                         Width="72"
                         VerticalContentAlignment="Center"
                         TextChanged="OnWidthChanged" />
                <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,16,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <TextBlock Text="높이" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox x:Name="HeightBox"
                         Width="72"
                         VerticalContentAlignment="Center"
                         TextChanged="OnHeightChanged" />
                <TextBlock Text="mm" VerticalAlignment="Center" Margin="4,0,16,0"
                           Foreground="{DynamicResource OnSurfaceMuted}" />
                <CheckBox x:Name="LockRatioCheck"
                          Content="비율 유지"
                          IsChecked="True"
                          VerticalAlignment="Center" />
            </StackPanel>

            <!-- 설명 행 -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="설명:" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="1"
                     x:Name="DescriptionBox"
                     VerticalContentAlignment="Center" />
        </Grid>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="삽입(_I)"
                    Width="96" Height="32"
                    Click="OnInsertClick"
                    IsDefault="True"
                    Margin="0,0,8,0" />
            <Button Content="닫기"
                    Width="96" Height="32"
                    Click="OnCloseClick"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
