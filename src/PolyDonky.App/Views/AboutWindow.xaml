<Window x:Class="PolyDonky.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PolyDonky 정보"
        Width="480"
        SizeToContent="Height"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/Assets/PolyDonky.ico"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="160" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Source="pack://application:,,,/Assets/PolyDonky_1024.png"
               Width="140" Height="140"
               HorizontalAlignment="Center" />

        <TextBlock Grid.Row="1"
                   Text="PolyDonky"
                   FontSize="28" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0" />

        <TextBlock Grid.Row="2"
                   x:Name="VersionText"
                   Text="버전 1.0.0-test.1"
                   Foreground="{DynamicResource OnSurfaceMuted}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />

        <StackPanel Grid.Row="3" Margin="24,16,24,0" HorizontalAlignment="Center">
            <TextBlock Text="Poly(gon) + Donky(당나귀)"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="다각형으로 거칠게 빚은 당나귀 — 외형은 엉성해도 어떤 문서 포맷이든 가리지 않고 먹어치운다."
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Text="A donkey roughly sculpted from polygons — clumsy on the outside, with a voracious appetite for any document format."
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource OnSurfaceMuted}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/Handtech_1024.png"
                   Width="64" Height="64"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="핸텍 (HANDTECH)"
                           FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="저작권자 / 메인테이너 — 노진문 (Noh JinMoon)"
                           Foreground="{DynamicResource OnSurfaceMuted}"
                           Margin="0,4,0,0" />
                <TextBlock Text="© 2026 HANDTECH. Mozilla Public License 2.0."
                           Foreground="{DynamicResource OnSurfaceMuted}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <Button Grid.Row="6"
                Content="확인"
                Width="96" Height="32"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OnOkClick" />
    </Grid>
</Window>
