<Window x:Class="PolyDonky.App.Views.TableInsertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="표 삽입"
        Width="300" Height="230"
        MinWidth="260" MinHeight="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" />
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 행 수 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="행 수:" VerticalAlignment="Center" />
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="RowsBox"
                   Text="3" TextAlignment="Right"
                   VerticalContentAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="2" Text="(1 ~ 100)" VerticalAlignment="Center"
                   Margin="8,0,0,0" Foreground="{DynamicResource OnSurfaceMuted}" FontSize="11" />

        <!-- 열 수 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="열 수:" VerticalAlignment="Center" />
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ColsBox"
                   Text="3" TextAlignment="Right"
                   VerticalContentAlignment="Center" />
        <TextBlock Grid.Row="2" Grid.Column="2" Text="(1 ~ 20)" VerticalAlignment="Center"
                   Margin="8,0,0,0" Foreground="{DynamicResource OnSurfaceMuted}" FontSize="11" />

        <!-- 너비 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="너비:" VerticalAlignment="Center" />
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="WidthBox"
                   Text="150" TextAlignment="Right"
                   VerticalContentAlignment="Center" />
        <TextBlock Grid.Row="4" Grid.Column="2" Text="mm  (0 = 자동)" VerticalAlignment="Center"
                   Margin="8,0,0,0" Foreground="{DynamicResource OnSurfaceMuted}" FontSize="11" />

        <!-- 머리글 행 -->
        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                  x:Name="HeaderRowCheck"
                  Content="첫 행을 머리글 행으로"
                  IsChecked="False" VerticalAlignment="Center" />

        <!-- 버튼 -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="삽입(_I)"
                    Width="88" Height="30"
                    IsDefault="True"
                    Click="OnInsertClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="30"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
