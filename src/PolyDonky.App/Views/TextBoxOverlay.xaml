<UserControl x:Class="PolyDonky.App.Views.TextBoxOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             FlowDirection="LeftToRight"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Focusable="True"
             PreviewMouseLeftButtonDown="OnRootMouseDown"
             MouseMove="OnRootMouseMove"
             PreviewMouseLeftButtonUp="OnRootMouseUp"
             KeyDown="OnRootKeyDown">

    <UserControl.ContextMenu>
        <ContextMenu Opened="OnContextMenuOpened">
            <MenuItem Header="속성(_P)..." Click="OnContextMenuProperties" />
            <MenuItem Header="글자 속성(_C)..." Click="OnContextMenuCharFormat" />
            <MenuItem Header="문단 속성(_A)..." Click="OnContextMenuParaFormat" />
            <Separator />
            <MenuItem Header="앞으로 가져오기(_F)" Click="OnContextMenuBringForward" />
            <MenuItem Header="뒤로 보내기(_B)" Click="OnContextMenuSendBack" />
            <Separator />
            <MenuItem Header="삭제(_D)" Click="OnContextMenuDelete" />
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <!-- 사각형 모양 (Rectangle) -->
        <Border x:Name="ShapeBorder"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1"
                Visibility="Visible" />

        <!-- 비사각형 모양 (Speech/Cloud/Spiky/Lightning) — Stretch=Fill 로 자동 스케일 -->
        <Path x:Name="ShapePath"
              Stretch="Fill"
              Fill="White"
              Stroke="Black"
              StrokeThickness="1"
              Visibility="Collapsed" />

        <!-- 내부 편집 영역 (RichTextBox 로 서식 있는 텍스트 지원) -->
        <RichTextBox x:Name="InnerEditor"
                     Background="Transparent"
                     BorderThickness="0"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Hidden"
                     HorizontalScrollBarVisibility="Disabled"
                     Margin="6"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     SpellCheck.IsEnabled="False"
                     TextChanged="OnInnerTextChanged"
                     FontFamily="{DynamicResource UiFont}">
            <RichTextBox.Resources>
                <!-- RichTextBox 기본 포커스 테두리 제거 -->
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0" />
                </Style>
            </RichTextBox.Resources>
            <!-- 본문 우클릭: 편집 + 글자/문단 서식. 외곽 우클릭(UserControl.ContextMenu)
                 과 별도 — 본문에서 RichTextBox 가 ContextMenu 를 직접 처리하므로
                 부모 메뉴는 가려진다. 이 메뉴는 텍스트 편집에 집중. -->
            <RichTextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="잘라내기(_T)" Command="ApplicationCommands.Cut" />
                    <MenuItem Header="복사(_C)"   Command="ApplicationCommands.Copy" />
                    <MenuItem Header="붙여넣기(_P)" Command="ApplicationCommands.Paste" />
                    <Separator />
                    <MenuItem Header="모두 선택(_A)" Command="ApplicationCommands.SelectAll" />
                    <Separator />
                    <MenuItem Header="글자 속성(_R)..." Click="OnContextMenuCharFormat" />
                    <MenuItem Header="문단 속성(_G)..." Click="OnContextMenuParaFormat" />
                </ContextMenu>
            </RichTextBox.ContextMenu>
        </RichTextBox>

        <!-- 선택 시에만 표시되는 chrome (점선 외곽 + 4코너 핸들) -->
        <Rectangle x:Name="SelectionFrame"
                   Stroke="#4A90E2"
                   StrokeThickness="1"
                   StrokeDashArray="3,2"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"
                   Margin="-1" />

        <Canvas x:Name="HandlesCanvas"
                IsHitTestVisible="True"
                Visibility="Collapsed">
            <Rectangle x:Name="HandleTL" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNWSE" Tag="TL"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleTR" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNESW" Tag="TR"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleBL" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNESW" Tag="BL"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleBR" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNWSE" Tag="BR"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
        </Canvas>
    </Grid>
</UserControl>
