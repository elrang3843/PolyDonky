<UserControl x:Class="PolyDonky.App.Controls.ColorPickerBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="26"
             VerticalAlignment="Center">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="26" />   <!-- 스와치 -->
            <ColumnDefinition Width="*" />    <!-- 텍스트 입력 -->
            <ColumnDefinition Width="30" />   <!-- ... 선택기 -->
            <ColumnDefinition Width="Auto" /> <!-- 없음 (조건부) -->
        </Grid.ColumnDefinitions>

        <!-- 색상 미리보기 스와치 -->
        <Border x:Name="Swatch"
                Grid.Column="0"
                Width="22" Height="22"
                CornerRadius="3"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Margin="0,0,4,0"
                VerticalAlignment="Center">
            <!-- 투명(없음) 상태를 나타내는 대각선 패턴 -->
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="Background" Value="{x:Null}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,8,8"
                                                  ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing Brush="White">
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="0,0,8,8" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <GeometryDrawing Brush="#CCCCCC">
                                                    <GeometryDrawing.Geometry>
                                                        <GeometryGroup>
                                                            <RectangleGeometry Rect="0,0,4,4" />
                                                            <RectangleGeometry Rect="4,4,4,4" />
                                                        </GeometryGroup>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- 직접 입력 TextBox -->
        <TextBox x:Name="ColorTextBox"
                 Grid.Column="1"
                 VerticalContentAlignment="Center"
                 TextChanged="OnTextChanged"
                 ToolTip="#RRGGBB 형식 또는 색상 이름 (red, blue ...)" />

        <!-- 색상 선택기 열기 버튼 -->
        <Button Grid.Column="2"
                Content="..."
                Width="28" Height="26"
                Click="OnPickClick"
                Margin="2,0,0,0"
                ToolTip="색상 선택기 열기" />

        <!-- 없음(지우기) 버튼 — AllowEmpty=false 이면 숨김 -->
        <Button x:Name="ClearButton"
                Grid.Column="3"
                Content="없음(_N)"
                Height="26"
                Padding="6,0"
                Click="OnClearClick"
                Margin="4,0,0,0"
                Visibility="Visible" />
    </Grid>
</UserControl>
