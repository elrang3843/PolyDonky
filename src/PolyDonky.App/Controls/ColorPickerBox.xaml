<UserControl x:Class="PolyDonky.App.Controls.ColorPickerBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="26"
             VerticalAlignment="Center">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="26" />   <!-- 스와치 -->
            <ColumnDefinition Width="*" />    <!-- 텍스트 입력 -->
            <ColumnDefinition Width="30" />   <!-- ... 선택기 -->
            <ColumnDefinition Width="Auto" /> <!-- 없음 (조건부) -->
        </Grid.ColumnDefinitions>

        <!-- 색상 미리보기 스와치 -->
        <Border x:Name="Swatch"
                Grid.Column="0"
                Width="22" Height="22"
                CornerRadius="3"
                BorderBrush="{DynamicResource OnSurfaceMuted}"
                BorderThickness="1"
                Margin="0,0,4,0"
                VerticalAlignment="Center" />

        <!-- 직접 입력 TextBox -->
        <TextBox x:Name="ColorTextBox"
                 Grid.Column="1"
                 VerticalContentAlignment="Center"
                 TextChanged="OnTextChanged"
                 ToolTip="#RRGGBB 형식 또는 색상 이름 (red, blue ...)" />

        <!-- 색상 선택기 열기 버튼 -->
        <Button Grid.Column="2"
                Content="..."
                Width="28" Height="26"
                Click="OnPickClick"
                Margin="2,0,0,0"
                ToolTip="색상 선택기 열기" />

        <!-- 없음(지우기) 버튼 — AllowEmpty=false 이면 숨김 -->
        <Button x:Name="ClearButton"
                Grid.Column="3"
                Content="없음(_N)"
                Height="26"
                Padding="6,0"
                Click="OnClearClick"
                Margin="4,0,0,0"
                Visibility="Visible" />
    </Grid>
</UserControl>
